@model List<BudgetMasterFinal.Models.ApplicationUser>
@{
    ViewData["Title"] = "Users";
    ViewData["PageTitle"] = "User Management";
    Layout = "_DashboardLayout";
}

<div class="dash-container">
    <div class="page-actions">
        <a href="/UserManagement/Create" class="btn-primary"><i class="fa-solid fa-user-plus"></i> Add User</a>
    </div>
    <div class="dash-card">
        <div class="card-header">
            <div class="card-title"><i class="fa-solid fa-users"></i> Users</div>
            <input type="text" class="filter-input" id="searchInput" placeholder="Search users..." onkeyup="filterTable()" />
        </div>
        <div class="card-body">
            <table class="dash-table" id="userTable">
                <thead>
                    <tr><th>Name</th><th>Email</th><th>Department</th><th>Role</th><th>Last Login</th><th>Status</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td>
                                <div class="user-cell">
                                    <div class="user-avatar-sm">@u.FirstName?.Substring(0,1)@u.LastName?.Substring(0,1)</div>
                                    <strong>@u.FullName</strong>
                                </div>
                            </td>
                            <td>@u.Email</td>
                            <td>@(u.Department?.Name ?? "—")</td>
                            <td><span class="role-badge role-@u.Role.ToLower()">@u.Role</span></td>
                            <td>@(u.LastLoginAt?.ToString("MMM dd, yyyy") ?? "Never")</td>
                            <td><span class="status-badge @(u.IsActive ? "status-active" : "status-closed")">@(u.IsActive ? "Active" : "Inactive")</span></td>
                            <td>
                                <div class="action-btns">
                                    <form action="/UserManagement/ToggleActive/@u.Id" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-icon @(u.IsActive ? "warning" : "success")" title="@(u.IsActive ? "Deactivate" : "Activate")">
                                            <i class="fa-solid @(u.IsActive ? "fa-user-slash" : "fa-user-check")"></i>
                                        </button>
                                    </form>
                                    <button class="btn-icon" onclick="openResetModal('@u.Id')" title="Reset Password">
                                        <i class="fa-solid fa-key"></i>
                                    </button>
                                    <form action="/UserManagement/Archive/@u.Id" method="post" style="display:inline" onsubmit="return confirm('Archive this user? You can restore them later from the Archive page.')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-icon warning" title="Archive"><i class="fa-solid fa-box-archive"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Reset Password Modal -->
<div class="modal-overlay" id="resetModal">
    <div class="modal-card">
        <div class="modal-header">
            <h3>Reset Password</h3>
            <button class="modal-close" onclick="document.getElementById('resetModal').classList.remove('open')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <form action="/UserManagement/ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="resetUserId" name="id" />
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">New Password</label>
                    <input type="password" name="newPassword" class="form-input" required minlength="6" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn-primary">Reset Password</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function filterTable() {
    const v = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('#userTable tbody tr').forEach(r => {
        r.style.display = r.textContent.toLowerCase().includes(v) ? '' : 'none';
    });
}
function openResetModal(id) {
    document.getElementById('resetUserId').value = id;
    document.getElementById('resetModal').classList.add('open');
}
</script>
}
