@model List<BudgetMasterFinal.Models.Tenant>
@{
    ViewData["Title"] = "Companies";
    ViewData["PageTitle"] = "Company Management";
    Layout = "_DashboardLayout";
}

<div class="dash-container">
    <div class="dash-card">
        <div class="card-header">
            <div class="card-title"><i class="fa-solid fa-building"></i> All Companies (Tenants)</div>
            <input type="text" class="filter-input" id="searchInput" placeholder="Search..." onkeyup="filterTable()" />
        </div>
        <div class="card-body">
            <table class="dash-table" id="tenantTable">
                <thead>
                    <tr><th>Company</th><th>Industry</th><th>Plan</th><th>Users</th><th>Created</th><th>Status</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td><strong>@t.CompanyName</strong></td>
                            <td>@(t.Industry ?? "—")</td>
                            <td>@(t.Subscription?.SubscriptionPlan?.Name ?? "None")</td>
                            <td>@t.Users.Count</td>
                            <td>@t.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td><span class="status-badge @(t.IsActive ? "status-active" : "status-closed")">@(t.IsActive ? "Active" : "Inactive")</span></td>
                            <td>
                                <div class="action-btns">
                                    <form action="/SuperAdmin/ToggleTenant/@t.Id" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-icon @(t.IsActive ? "warning" : "")" title="@(t.IsActive ? "Deactivate" : "Activate")">
                                            <i class="fa-solid @(t.IsActive ? "fa-lock" : "fa-lock-open")"></i>
                                        </button>
                                    </form>
                                    <form action="/SuperAdmin/ArchiveTenant/@t.Id" method="post" style="display:inline" onsubmit="return confirm('Archive this tenant? You can restore it later from the Archive page.')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-icon warning" title="Archive"><i class="fa-solid fa-box-archive"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
function filterTable() {
    const v = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('#tenantTable tbody tr').forEach(r => {
        r.style.display = r.textContent.toLowerCase().includes(v) ? '' : 'none';
    });
}
</script>
}
