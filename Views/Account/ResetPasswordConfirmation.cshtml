@{
    ViewData["Title"] = "Password Reset Successful";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-left">
        <div class="auth-left-content">
            <div class="auth-brand">
                <div class="brand-icon-lg"><i class="fa-solid fa-chart-pie"></i></div>
                <span class="auth-brand-name">BudgetMaster</span>
            </div>
            <h2 class="auth-tagline">Password Reset Complete!</h2>
            <p class="auth-desc">Your password has been successfully reset. You can now log in with your new password and access your account.</p>
            <div class="auth-features">
                <div class="auth-feat"><i class="fa-solid fa-check-circle"></i> Password Successfully Updated</div>
                <div class="auth-feat"><i class="fa-solid fa-check-circle"></i> Account Secured</div>
                <div class="auth-feat"><i class="fa-solid fa-check-circle"></i> Ready to Log In</div>
            </div>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-card">
            <div class="auth-card-header" style="text-align: center;">
                <div style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #10b981, #059669); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
                    <i class="fa-solid fa-circle-check" style="font-size: 40px; color: white;"></i>
                </div>
                <h1 class="auth-title">Password Reset Successful!</h1>
                <p class="auth-subtitle" style="font-size: 16px; line-height: 1.6;">
                    Your password has been successfully reset. You can now log in with your new password.
                </p>
            </div>

            <div class="auth-form" style="text-align: center;">
                <a href="/Account/Login" class="btn-auth-primary" style="display: inline-block; text-decoration: none; width: 100%; text-align: center;">
                    <i class="fa-solid fa-right-to-bracket"></i> Go to Login
                </a>
            </div>

            <p class="auth-back"><a href="/"><i class="fa-solid fa-arrow-left"></i> Back to home</a></p>
        </div>
    </div>
</div>
