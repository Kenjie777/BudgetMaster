@{
    ViewData["Title"] = "Password Reset Email Sent";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-left">
        <div class="auth-left-content">
            <div class="auth-brand">
                <div class="brand-icon-lg"><i class="fa-solid fa-chart-pie"></i></div>
                <span class="auth-brand-name">BudgetMaster</span>
            </div>
            <h2 class="auth-tagline">Check Your Email</h2>
            <p class="auth-desc">We've sent you a secure password reset link. Follow the instructions in the email to reset your password.</p>
            <div class="auth-features">
                <div class="auth-feat"><i class="fa-solid fa-check-circle"></i> Secure Reset Link Sent</div>
                <div class="auth-feat"><i class="fa-solid fa-check-circle"></i> Check Your Inbox</div>
                <div class="auth-feat"><i class="fa-solid fa-check-circle"></i> Link Expires in 24 Hours</div>
            </div>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-card">
            <div class="auth-card-header" style="text-align: center;">
                <div style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #10b981, #059669); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
                    <i class="fa-solid fa-envelope-circle-check" style="font-size: 40px; color: white;"></i>
                </div>
                <h1 class="auth-title">Check Your Email</h1>
                <p class="auth-subtitle" style="font-size: 16px; line-height: 1.6;">
                    If an account with that email exists, we've sent you a password reset link. 
                    Please check your inbox and follow the instructions to reset your password.
                </p>
            </div>

            <div class="auth-form" style="text-align: center;">
                <div style="padding: 20px; background: #f3f4f6; border-radius: 8px; margin-bottom: 24px;">
                    <p style="margin: 0; color: #6b7280; font-size: 14px;">
                        <i class="fa-solid fa-info-circle"></i> 
                        Didn't receive the email? Check your spam folder or try again in a few minutes.
                    </p>
                </div>

                <a href="/Account/Login" class="btn-auth-primary" style="display: inline-block; text-decoration: none; width: 100%; text-align: center;">
                    <i class="fa-solid fa-arrow-left"></i> Back to Login
                </a>

                <div style="margin-top: 24px;">
                    <a href="/Account/ForgotPassword" style="color: #1e3a5f; text-decoration: none; font-size: 14px;">
                        <i class="fa-solid fa-rotate-right"></i> Resend Reset Link
                    </a>
                </div>
            </div>

            <p class="auth-back"><a href="/"><i class="fa-solid fa-arrow-left"></i> Back to home</a></p>
        </div>
    </div>
</div>
