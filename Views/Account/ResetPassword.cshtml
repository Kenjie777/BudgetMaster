@model BudgetMasterFinal.Models.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-left">
        <div class="auth-left-content">
            <div class="auth-brand">
                <div class="brand-icon-lg"><i class="fa-solid fa-chart-pie"></i></div>
                <span class="auth-brand-name">BudgetMaster</span>
            </div>
            <h2 class="auth-tagline">Create a New Password</h2>
            <p class="auth-desc">Choose a strong password to secure your account. Make sure it's at least 6 characters and contains a number.</p>
            <div class="auth-features">
                <div class="auth-feat"><i class="fa-solid fa-check-circle"></i> Secure Password Reset</div>
                <div class="auth-feat"><i class="fa-solid fa-check-circle"></i> Strong Password Required</div>
                <div class="auth-feat"><i class="fa-solid fa-check-circle"></i> Instant Access After Reset</div>
            </div>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-card">
            <div class="auth-card-header">
                <div class="auth-welcome-logo">
                    <img src="~/images/BudgetMasterLogo1.png" alt="BudgetMaster" class="welcome-logo" />
                </div>
                <h1 class="auth-title">Reset Your Password</h1>
                <p class="auth-subtitle">Enter your new password below.</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="auth-error">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <div asp-validation-summary="ModelOnly"></div>
                </div>
            }

            <form asp-action="ResetPassword" method="post" class="auth-form">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Token" />
                <input type="hidden" asp-for="Email" />

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-envelope input-icon"></i>
                        <input asp-for="Email" class="form-input" readonly style="background: #f3f4f6; cursor: not-allowed;" />
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">New Password</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-lock input-icon"></i>
                        <input asp-for="Password" 
                               type="password" 
                               class="form-input" 
                               id="passwordInput"
                               placeholder="Enter new password" 
                               required 
                               autofocus />
                        <button type="button" class="input-toggle" onclick="togglePassword('passwordInput', this)">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                    <small style="font-size: 0.75rem; color: #6b7280; display: block; margin-top: 4px;">
                        Password must be at least 6 characters and contain a number.
                    </small>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword" class="form-label">Confirm New Password</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-lock input-icon"></i>
                        <input asp-for="ConfirmPassword" 
                               type="password" 
                               class="form-input" 
                               id="confirmPasswordInput"
                               placeholder="Confirm new password" 
                               required />
                        <button type="button" class="input-toggle" onclick="togglePassword('confirmPasswordInput', this)">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                </div>

                <button type="submit" class="btn-auth-primary">
                    <i class="fa-solid fa-check"></i> Reset Password
                </button>
            </form>

            <p class="auth-back"><a href="/Account/Login"><i class="fa-solid fa-arrow-left"></i> Back to login</a></p>
        </div>
    </div>
</div>

@section Scripts {
<script>
function togglePassword(id, btn) {
    const input = document.getElementById(id);
    const icon = btn.querySelector('i');
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'fa-solid fa-eye-slash';
    } else {
        input.type = 'password';
        icon.className = 'fa-solid fa-eye';
    }
}
</script>
<partial name="_ValidationScriptsPartial" />
}
