@{
    ViewData["Title"] = "Access Denied";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-left">
        <div class="auth-left-content">
            <div class="auth-brand">
                <img src="~/images/BudgetMasterLogo1.png" alt="BudgetMaster" class="nav-logo" style="filter: brightness(0) invert(1);" />
            </div>
            <h1 class="auth-tagline">Secure & Isolated.</h1>
            <p class="auth-desc">BudgetMaster employs enterprise-grade security and role-based access control to ensure your financial data remains private and protected at all times.</p>
        </div>
    </div>
    
    <div class="auth-right">
        <div class="auth-card">
            <div class="auth-card-header" style="text-align: center;">
                <div style="font-size: 3rem; color: var(--danger); margin-bottom: 1rem;">
                    <i class="fa-solid fa-shield-halved"></i>
                </div>
                <h2 class="auth-title">Access Denied</h2>
                <p class="auth-subtitle">You do not have permission to view this page.</p>
            </div>
            
            <div style="text-align: center; margin-top: 2rem;">
                <p style="color: var(--muted); font-size: 0.9rem; margin-bottom: 1.5rem;">
                    If you believe you should have access, please contact your Company Administrator.
                </p>
                <a href="/" class="btn-auth-primary" style="text-decoration: none; display: inline-flex;">
                    <i class="fa-solid fa-house"></i> Return to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
