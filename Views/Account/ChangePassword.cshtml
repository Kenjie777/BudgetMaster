@{
    ViewData["Title"] = ViewBag.IsFirstLogin ? "Change Temporary Password" : "Change Password";
    Layout = ViewBag.IsFirstLogin ? "~/Views/Shared/_AuthLayout.cshtml" : "_DashboardLayout";
    var isFirstLogin = ViewBag.IsFirstLogin ?? false;
    var userEmail = ViewBag.UserEmail ?? "";
}

@if (isFirstLogin)
{
    <!-- First Login - Full Page Layout -->
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <div class="auth-logo">
                    <img src="~/images/BudgetMasterLogo1.png" alt="BudgetMaster" style="height: 50px;" />
                </div>
                <h1 style="margin: 20px 0 10px 0;">🔐 Change Your Password</h1>
                <p style="color: #666; margin: 0;">Welcome! For security reasons, you must change your temporary password.</p>
            </div>

            @if (TempData["Info"] != null)
            {
                <div class="alert alert-info" style="background: #d1ecf1; border-left: 4px solid #0c5460; padding: 15px; margin: 20px 0; border-radius: 4px; color: #0c5460;">
                    <i class="fa-solid fa-info-circle"></i> @TempData["Info"]
                </div>
            }

            <form asp-action="ChangePassword" method="post" class="auth-form">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="auth-error"></div>

                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-envelope"></i> Email Address
                    </label>
                    <input type="text" value="@userEmail" class="form-input" disabled style="background: #f8f9fa; color: #666;" />
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-key"></i> Current (Temporary) Password <span class="required">*</span>
                    </label>
                    <div class="password-input-wrapper">
                        <input type="password" name="currentPassword" id="currentPassword" class="form-input" required placeholder="Enter your temporary password" />
                        <button type="button" class="password-toggle" onclick="togglePassword('currentPassword')">
                            <i class="fa-solid fa-eye" id="currentPassword-icon"></i>
                        </button>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-lock"></i> New Password <span class="required">*</span>
                    </label>
                    <div class="password-input-wrapper">
                        <input type="password" name="newPassword" id="newPassword" class="form-input" required placeholder="Enter your new password" />
                        <button type="button" class="password-toggle" onclick="togglePassword('newPassword')">
                            <i class="fa-solid fa-eye" id="newPassword-icon"></i>
                        </button>
                    </div>
                    <div class="password-requirements" style="margin-top: 10px; font-size: 12px; color: #666;">
                        <strong>Password Requirements:</strong>
                        <ul style="margin: 5px 0; padding-left: 20px;">
                            <li>At least 12 characters long</li>
                            <li>Contains uppercase letter (A-Z)</li>
                            <li>Contains lowercase letter (a-z)</li>
                            <li>Contains number (0-9)</li>
                            <li>Contains special character</li>
                        </ul>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-lock"></i> Confirm New Password <span class="required">*</span>
                    </label>
                    <div class="password-input-wrapper">
                        <input type="password" name="confirmPassword" id="confirmPassword" class="form-input" required placeholder="Confirm your new password" />
                        <button type="button" class="password-toggle" onclick="togglePassword('confirmPassword')">
                            <i class="fa-solid fa-eye" id="confirmPassword-icon"></i>
                        </button>
                    </div>
                </div>

                <div style="background: #fff3cd; border-left: 4px solid #ffc107; padding: 15px; margin: 20px 0; border-radius: 4px;">
                    <strong style="color: #856404;"><i class="fa-solid fa-shield-halved"></i> Security Tips:</strong>
                    <ul style="margin: 10px 0 0 0; padding-left: 20px; color: #856404;">
                        <li>Choose a strong, unique password</li>
                        <li>Don't reuse passwords from other accounts</li>
                        <li>Consider using a password manager</li>
                        <li>Never share your password with anyone</li>
                    </ul>
                </div>

                <button type="submit" class="btn-primary" style="width: 100%; padding: 14px; font-size: 16px;">
                    <i class="fa-solid fa-check"></i> Change Password & Continue
                </button>
            </form>
        </div>
    </div>

    <script>
        function togglePassword(fieldId) {
            const field = document.getElementById(fieldId);
            const icon = document.getElementById(fieldId + '-icon');
            if (field.type === 'password') {
                field.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                field.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }
    </script>
}
else
{
    <!-- Regular Password Change - Dashboard Layout -->
    <div class="dash-container">
        <div class="form-card">
            <div class="form-card-header">
                <i class="fa-solid fa-key"></i>
                <h2>Change Password</h2>
                <p style="margin: 10px 0 0 0; color: #666;">Update your account password</p>
            </div>

            <form asp-action="ChangePassword" method="post" class="erp-form">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="auth-error"></div>

                <div class="form-group">
                    <label class="form-label">Current Password <span class="required">*</span></label>
                    <input type="password" name="currentPassword" class="form-input" required />
                </div>

                <div class="form-group">
                    <label class="form-label">New Password <span class="required">*</span></label>
                    <input type="password" name="newPassword" class="form-input" required />
                    <small style="color: #666;">Minimum 12 characters with uppercase, lowercase, number, and special character</small>
                </div>

                <div class="form-group">
                    <label class="form-label">Confirm New Password <span class="required">*</span></label>
                    <input type="password" name="confirmPassword" class="form-input" required />
                </div>

                <div class="form-actions">
                    <a href="/Dashboard/Index" class="btn-secondary"><i class="fa-solid fa-times"></i> Cancel</a>
                    <button type="submit" class="btn-primary"><i class="fa-solid fa-save"></i> Change Password</button>
                </div>
            </form>
        </div>
    </div>
}
