@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-left">
        <div class="auth-left-content">
            <div class="auth-brand">
                <div class="brand-icon-lg"><i class="fa-solid fa-chart-pie"></i></div>
                <span class="auth-brand-name">BudgetMaster</span>
            </div>
            <h2 class="auth-tagline">Reset Your Password</h2>
            <p class="auth-desc">Enter your email address and we'll send you a secure link to reset your password.</p>
            <div class="auth-features">
                <div class="auth-feat"><i class="fa-solid fa-check-circle"></i> Secure Password Reset</div>
                <div class="auth-feat"><i class="fa-solid fa-check-circle"></i> Email Verification</div>
                <div class="auth-feat"><i class="fa-solid fa-check-circle"></i> Quick & Easy Process</div>
            </div>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-card">
            <div class="auth-card-header">
                <div class="auth-welcome-logo">
                    <img src="~/images/BudgetMasterLogo1.png" alt="BudgetMaster" class="welcome-logo" />
                </div>
                <h1 class="auth-title">Forgot Password</h1>
                <p class="auth-subtitle">Enter your email address and we'll send you a link to reset your password.</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="auth-error">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <div asp-validation-summary="ModelOnly"></div>
                </div>
            }

            <form asp-action="ForgotPassword" method="post" class="auth-form">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label for="email" class="form-label">Email Address</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-envelope input-icon"></i>
                        <input type="email" 
                               id="email" 
                               name="email" 
                               class="form-input" 
                               placeholder="you@company.com" 
                               required 
                               autofocus />
                    </div>
                </div>

                <button type="submit" class="btn-auth-primary">
                    <i class="fa-solid fa-paper-plane"></i> Send Reset Link
                </button>
            </form>

            <p class="auth-back"><a href="/Account/Login"><i class="fa-solid fa-arrow-left"></i> Back to login</a></p>
        </div>
    </div>
</div>
