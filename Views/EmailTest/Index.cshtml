@{
    ViewData["Title"] = "Email Configuration Test";
    ViewData["PageTitle"] = "Email Configuration Test";
    Layout = "_DashboardLayout";
    var isConfigured = ViewBag.IsConfigured ?? false;
}

<div class="dash-container">
    <div class="form-card">
        <div class="form-card-header">
            <i class="fa-solid fa-envelope-circle-check"></i>
            <h2>Email Configuration Test</h2>
            <p style="margin: 10px 0 0 0; color: #666;">Test your Gmail SMTP configuration</p>
        </div>

        @if (!isConfigured)
        {
            <div style="background: #fff3cd; border-left: 4px solid #ffc107; padding: 20px; margin: 20px; border-radius: 4px;">
                <h3 style="color: #856404; margin-top: 0;"><i class="fa-solid fa-exclamation-triangle"></i> Email Not Configured</h3>
                <p style="color: #856404; margin: 10px 0;">Your email settings are not configured yet. Please follow these steps:</p>
                
                <ol style="color: #856404; margin: 15px 0; padding-left: 20px;">
                    <li><strong>Enable 2-Factor Authentication</strong> on your Gmail account</li>
                    <li><strong>Generate App Password:</strong>
                        <ul style="margin: 5px 0;">
                            <li>Go to <a href="https://myaccount.google.com/apppasswords" target="_blank" style="color: #0066cc;">https://myaccount.google.com/apppasswords</a></li>
                            <li>Select "Mail" and "Windows Computer"</li>
                            <li>Click "Generate"</li>
                            <li>Copy the 16-character password (remove spaces)</li>
                        </ul>
                    </li>
                    <li><strong>Update appsettings.json:</strong>
                        <pre style="background: #f8f9fa; padding: 15px; border-radius: 4px; overflow-x: auto; margin: 10px 0;">
"Email": {
  "SmtpHost": "smtp.gmail.com",
  "SmtpPort": "587",
  "SmtpUsername": "<strong style="color: #dc3545;">your-actual-email@gmail.com</strong>",
  "SmtpPassword": "<strong style="color: #dc3545;">your-16-char-app-password</strong>",
  "FromEmail": "<strong style="color: #dc3545;">your-actual-email@gmail.com</strong>",
  "FromName": "BudgetMaster"
}</pre>
                    </li>
                    <li><strong>Restart the application</strong> after updating the configuration</li>
                </ol>
            </div>
        }
        else
        {
            <div style="background: #d1ecf1; border-left: 4px solid #0c5460; padding: 20px; margin: 20px; border-radius: 4px;">
                <h3 style="color: #0c5460; margin-top: 0;"><i class="fa-solid fa-check-circle"></i> Email Configuration Detected</h3>
                <p style="color: #0c5460; margin: 0;"><strong>SMTP Host:</strong> @ViewBag.SmtpHost</p>
                <p style="color: #0c5460; margin: 5px 0 0 0;"><strong>SMTP Port:</strong> @ViewBag.SmtpPort</p>
                <p style="color: #0c5460; margin: 5px 0 0 0;"><strong>Username:</strong> @ViewBag.SmtpUsername</p>
            </div>
        }

        <div style="padding: 20px;">
            <h3><i class="fa-solid fa-paper-plane"></i> Send Test Email</h3>
            <p style="color: #666; margin-bottom: 20px;">Enter your email address to receive a test email and verify the configuration.</p>

            <form asp-action="SendTest" method="post">
                @Html.AntiForgeryToken()
                
                <div class="form-group">
                    <label class="form-label">Test Email Address <span class="required">*</span></label>
                    <input type="email" name="testEmail" class="form-input" placeholder="your-email@gmail.com" required />
                    <small style="color: #666;">We'll send a test email to this address</small>
                </div>

                <div class="form-actions">
                    <a href="/Dashboard/Index" class="btn-secondary"><i class="fa-solid fa-arrow-left"></i> Back to Dashboard</a>
                    <button type="submit" class="btn-primary" @(!isConfigured ? "disabled" : "")>
                        <i class="fa-solid fa-paper-plane"></i> Send Test Email
                    </button>
                </div>
            </form>
        </div>

        <div style="background: #e7f3ff; padding: 20px; margin: 20px; border-radius: 4px; border-left: 4px solid #0066cc;">
            <h3 style="color: #004085; margin-top: 0;"><i class="fa-solid fa-lightbulb"></i> Troubleshooting Tips</h3>
            <ul style="color: #004085; margin: 10px 0; padding-left: 20px;">
                <li><strong>Check spam folder:</strong> Gmail might filter automated emails</li>
                <li><strong>Verify 2FA is enabled:</strong> App passwords require 2-Factor Authentication</li>
                <li><strong>Use app password, not regular password:</strong> Gmail blocks regular passwords for SMTP</li>
                <li><strong>Check firewall:</strong> Ensure port 587 is not blocked</li>
                <li><strong>Review logs:</strong> Check application logs for detailed error messages</li>
                <li><strong>Gmail limits:</strong> Free accounts: ~500 emails/day, Workspace: ~2,000/day</li>
            </ul>
        </div>

        <div style="background: #f8f9fa; padding: 20px; margin: 20px; border-radius: 4px;">
            <h3 style="margin-top: 0;"><i class="fa-solid fa-book"></i> Common Error Messages</h3>
            <table style="width: 100%; border-collapse: collapse;">
                <tr style="border-bottom: 1px solid #dee2e6;">
                    <td style="padding: 10px; font-weight: 600;">Error</td>
                    <td style="padding: 10px; font-weight: 600;">Solution</td>
                </tr>
                <tr style="border-bottom: 1px solid #dee2e6;">
                    <td style="padding: 10px; vertical-align: top;">"Authentication failed"</td>
                    <td style="padding: 10px;">Wrong username or password. Use app-specific password, not regular Gmail password.</td>
                </tr>
                <tr style="border-bottom: 1px solid #dee2e6;">
                    <td style="padding: 10px; vertical-align: top;">"Connection refused"</td>
                    <td style="padding: 10px;">Check SMTP host (smtp.gmail.com) and port (587). Verify firewall settings.</td>
                </tr>
                <tr style="border-bottom: 1px solid #dee2e6;">
                    <td style="padding: 10px; vertical-align: top;">"Less secure app access"</td>
                    <td style="padding: 10px;">Enable 2FA and use app-specific password instead.</td>
                </tr>
                <tr>
                    <td style="padding: 10px; vertical-align: top;">"Email not sent"</td>
                    <td style="padding: 10px;">Configuration incomplete. Update appsettings.json with real credentials.</td>
                </tr>
            </table>
        </div>
    </div>
</div>
