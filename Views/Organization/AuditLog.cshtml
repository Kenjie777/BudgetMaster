@model BudgetMasterFinal.Models.ViewModels.OrganizationAuditLogViewModel
@{
    ViewData["Title"] = "Organization Audit Log";
    ViewData["PageTitle"] = "Organization Audit Log";
}

<div class="dash-container">
    <div class="page-actions">
        <button type="button" class="btn-secondary" onclick="exportAuditLog()">
            <i class="fa-solid fa-download"></i> Export Log
        </button>
    </div>

    <!-- Filters Card -->
    <div class="dash-card">
        <div class="card-header">
            <div class="card-title">
                <i class="fa-solid fa-filter"></i>
                Filter Audit Log
            </div>
        </div>
        <div class="card-body">
            <form method="get" style="display: flex; align-items: end; gap: 1rem; flex-wrap: wrap;">
                <div style="display: flex; flex-direction: column; gap: 0.25rem; min-width: 200px;">
                    <label for="action" style="font-size: 0.75rem; font-weight: 500; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Action</label>
                    <input type="text" id="action" name="action" value="@Model.ActionFilter" 
                           class="filter-input" placeholder="Filter by action..." />
                </div>
                <div style="display: flex; flex-direction: column; gap: 0.25rem; min-width: 200px;">
                    <label for="entity" style="font-size: 0.75rem; font-weight: 500; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Entity</label>
                    <input type="text" id="entity" name="entity" value="@Model.EntityFilter" 
                           class="filter-input" placeholder="Filter by entity..." />
                </div>
                <div style="display: flex; gap: 0.5rem;">
                    <button type="submit" class="btn-primary">
                        <i class="fa-solid fa-filter"></i> Apply Filters
                    </button>
                    <a href="@Url.Action("AuditLog")" class="btn-secondary">
                        <i class="fa-solid fa-times"></i> Clear
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Audit Log Card -->
    <div class="dash-card">
        <div class="card-header">
            <div class="card-title">
                <i class="fa-solid fa-history"></i>
                Activity Log
            </div>
            <div style="font-size: 0.875rem; color: #64748b;">
                Showing @Model.Logs.Count of @Model.TotalCount total entries
            </div>
        </div>
        <div class="card-body">
            @if (Model.Logs.Any())
            {
                <div class="audit-timeline">
                    @foreach (var log in Model.Logs)
                    {
                        <div class="timeline-item">
                            <div class="timeline-marker">
                                <div class="timeline-icon @(GetActionClass(log.Action))">
                                    <i class="@(GetActionIcon(log.Action))"></i>
                                </div>
                            </div>
                            <div class="timeline-content">
                                <div class="timeline-header">
                                    <div class="timeline-title">@log.Action</div>
                                    <div class="timeline-time">@log.Timestamp.ToString("MMM dd, yyyy HH:mm")</div>
                                </div>
                                <table class="dash-table" style="margin-top: 0.75rem;">
                                    <tr>
                                        <td style="font-weight: 600; color: #64748b; width: 100px;">User:</td>
                                        <td>@(log.User?.FullName ?? "System")</td>
                                    </tr>
                                    <tr>
                                        <td style="font-weight: 600; color: #64748b;">Entity:</td>
                                        <td>@log.EntityType</td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(log.NewValues))
                                    {
                                        <tr>
                                            <td style="font-weight: 600; color: #64748b;">Details:</td>
                                            <td>@log.NewValues</td>
                                        </tr>
                                    }
                                    @if (!string.IsNullOrEmpty(log.IpAddress))
                                    {
                                        <tr>
                                            <td style="font-weight: 600; color: #64748b;">IP Address:</td>
                                            <td>@log.IpAddress</td>
                                        </tr>
                                    }
                                </table>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid #e5e7eb;">
                        <nav style="display: flex; justify-content: space-between; align-items: center;">
                            @if (Model.CurrentPage > 1)
                            {
                                <a href="@Url.Action("AuditLog", new { page = Model.CurrentPage - 1, action = Model.ActionFilter, entity = Model.EntityFilter })" 
                                   class="btn-secondary">
                                    <i class="fa-solid fa-chevron-left"></i> Previous
                                </a>
                            }
                            else
                            {
                                <div></div>
                            }
                            
                            <div style="font-size: 0.875rem; color: #64748b;">
                                Page @Model.CurrentPage of @Model.TotalPages
                            </div>
                            
                            @if (Model.CurrentPage < Model.TotalPages)
                            {
                                <a href="@Url.Action("AuditLog", new { page = Model.CurrentPage + 1, action = Model.ActionFilter, entity = Model.EntityFilter })" 
                                   class="btn-secondary">
                                    Next <i class="fa-solid fa-chevron-right"></i>
                                </a>
                            }
                            else
                            {
                                <div></div>
                            }
                        </nav>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="fa-solid fa-history"></i>
                    <h3>No Audit Logs Found</h3>
                    <p>
                        @if (!string.IsNullOrEmpty(Model.ActionFilter) || !string.IsNullOrEmpty(Model.EntityFilter))
                        {
                            <span>No logs match your current filters. Try adjusting your search criteria.</span>
                        }
                        else
                        {
                            <span>No audit logs have been recorded yet for your organization.</span>
                        }
                    </p>
                </div>
            }
        </div>
    </div>
</div>

<style>
.audit-timeline {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.timeline-item {
    display: flex;
    gap: 1rem;
    position: relative;
}

.timeline-item:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 1.25rem;
    top: 2.5rem;
    bottom: -1rem;
    width: 2px;
    background: #e5e7eb;
}

.timeline-marker {
    flex-shrink: 0;
}

.timeline-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    color: white;
    font-size: 0.875rem;
}

.timeline-icon.create {
    background: #10b981;
}

.timeline-icon.update {
    background: #3b82f6;
}

.timeline-icon.delete {
    background: #ef4444;
}

.timeline-icon.login {
    background: #8b5cf6;
}

.timeline-icon.default {
    background: #6b7280;
}

.timeline-content {
    flex: 1;
    background: #f8fafc;
    border-radius: 0.75rem;
    border: 1px solid #e2e8f0;
    padding: 1rem;
}

.timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
}

.timeline-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1e293b;
}

.timeline-time {
    font-size: 0.75rem;
    color: #64748b;
}
</style>

@section Scripts {
<script>
function exportAuditLog() {
    // This would typically make an API call to export the audit log
    alert('Export functionality would be implemented here. This would generate a CSV or PDF report of the audit log.');
}
</script>
}

@functions {
    string GetActionClass(string action)
    {
        return action.ToLower() switch
        {
            var a when a.Contains("create") => "create",
            var a when a.Contains("update") || a.Contains("edit") => "update", 
            var a when a.Contains("delete") => "delete",
            var a when a.Contains("login") => "login",
            _ => "default"
        };
    }
    
    string GetActionIcon(string action)
    {
        return action.ToLower() switch
        {
            var a when a.Contains("create") => "fa-solid fa-plus",
            var a when a.Contains("update") || a.Contains("edit") => "fa-solid fa-edit",
            var a when a.Contains("delete") => "fa-solid fa-trash",
            var a when a.Contains("login") => "fa-solid fa-sign-in-alt",
            _ => "fa-solid fa-info-circle"
        };
    }
}