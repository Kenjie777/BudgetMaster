@model IEnumerable<BudgetMasterFinal.Models.BudgetRequest>
@{
    ViewData["Title"] = "Approval Workflow";
    var department = ViewBag.Department as BudgetMasterFinal.Models.Department;
}

<div class="dash-container">
    <!-- KPI Cards -->
    <div class="kpi-grid">
        <div class="kpi-card orange">
            <div class="kpi-icon"><i class="fa-solid fa-clock"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">PENDING</div>
                <div class="kpi-value">@Model.Count()</div>
                <div class="kpi-sub">requests</div>
            </div>
        </div>
        <div class="kpi-card blue">
            <div class="kpi-icon"><i class="fa-solid fa-dollar-sign"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">VALUE</div>
                <div class="kpi-value">@Model.Sum(r => r.RequestedAmount).ToString("C0")</div>
                <div class="kpi-sub">total</div>
            </div>
        </div>
        <div class="kpi-card teal">
            <div class="kpi-icon"><i class="fa-solid fa-user-check"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">STAGE</div>
                <div class="kpi-value">1</div>
                <div class="kpi-sub">operational</div>
            </div>
        </div>
        <div class="kpi-card green">
            <div class="kpi-icon"><i class="fa-solid fa-building"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">DEPARTMENT</div>
                <div class="kpi-value">@department?.Name</div>
                <div class="kpi-sub">authority</div>
            </div>
        </div>
    </div>

    @if (Model.Any())
    {
        <!-- Pending Requests -->
        <div class="dash-card">
            <div class="card-header">
                <div class="card-title"><i class="fa-solid fa-clipboard-check"></i> Requests</div>
            </div>
            <div class="card-body">
                <div class="requests-grid">
                    @foreach (var request in Model)
                    {
                        <div class="req-card">
                            <div class="req-card-header">
                                <div class="req-avatar-lg">
                                    @request.RequestedByUser?.FirstName?.Substring(0, 1)@request.RequestedByUser?.LastName?.Substring(0, 1)
                                </div>
                                <div class="req-card-info">
                                    <div class="req-card-name">@request.RequestedByUser?.FullName</div>
                                    <div class="req-card-dept">@request.CreatedAt.ToString("MMM dd, yyyy")</div>
                                </div>
                            </div>
                            <div class="req-card-body">
                                <div class="req-card-title">@request.Title</div>
                                <div class="req-amount">@request.RequestedAmount.ToString("C")</div>
                                <div class="req-category">
                                    <span class="status-badge status-@request.Category.ToLower()">@request.Category</span>
                                </div>
                                @if (!string.IsNullOrEmpty(request.Justification))
                                {
                                    <div class="req-justification">
                                        @request.Justification
                                    </div>
                                }
                            </div>
                            <div class="req-card-actions">
                                <button class="btn-approve" onclick="approveRequest(@request.Id, 'Approved')">
                                    <i class="fa-solid fa-check"></i>
                                    Approve
                                </button>
                                <button class="btn-reject" onclick="rejectRequest(@request.Id)">
                                    <i class="fa-solid fa-times"></i>
                                    Reject
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="dash-card">
            <div class="card-body">
                <div class="empty-state">
                    <i class="fa-solid fa-check-circle"></i>
                    <h3>All Caught Up</h3>
                    <p>No pending requests</p>
                    <a href="/Budget/DepartmentRequests" class="btn-secondary">View All</a>
                </div>
            </div>
        </div>
    }
</div>

<!-- Approval Modal -->
<div class="modal-overlay" id="approvalModal">
    <div class="modal-card">
        <div class="modal-header">
            <h3 id="modalTitle">Approval</h3>
            <button class="modal-close" onclick="closeModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <form id="approvalForm" method="post" action="/Budget/ApproveRequest">
            @Html.AntiForgeryToken()
            <input type="hidden" id="requestId" name="id" />
            <input type="hidden" id="action" name="action" />
            <div class="modal-body">
                <div style="display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; padding: 1rem; background: #f8fafc; border-radius: 8px; gap: 1rem;">
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; background: #f59e0b; color: white; font-size: 0.875rem;">1</div>
                        <div>
                            <div style="font-weight: 600; color: #1e293b; margin-bottom: 0.125rem; font-size: 0.875rem;">Operational Approval</div>
                            <div style="font-size: 0.75rem; color: #64748b;">You are here - Department Head review</div>
                        </div>
                    </div>
                    <div style="color: #9ca3af; font-size: 1.25rem; font-weight: bold;">→</div>
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; background: #e5e7eb; color: #6b7280; font-size: 0.875rem;">2</div>
                        <div>
                            <div style="font-weight: 600; color: #1e293b; margin-bottom: 0.125rem; font-size: 0.875rem;">Financial Validation</div>
                            <div style="font-size: 0.75rem; color: #64748b;">Finance Manager final approval</div>
                        </div>
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="notes" style="display: block; font-size: 0.875rem; font-weight: 600; color: #374151; margin-bottom: 0.5rem;">Notes</label>
                    <textarea id="notes" name="notes" class="form-input form-textarea" rows="3" placeholder="Add comments or conditions..."></textarea>
                    <small style="font-size: 0.75rem; color: #64748b; margin-top: 0.25rem; display: block;">Visible to Finance Manager</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-secondary" onclick="closeModal()">Cancel</button>
                <button type="submit" class="btn-primary" id="confirmButton">Approve</button>
            </div>
        </form>
    </div>
</div>



<script>
function approveRequest(id, action) {
    document.getElementById('requestId').value = id;
    document.getElementById('action').value = action;
    document.getElementById('modalTitle').textContent = action === 'Approved' ? 'Approval' : 'Reject';
    document.getElementById('confirmButton').textContent = action === 'Approved' ? 'Approve' : 'Reject';
    document.getElementById('confirmButton').className = action === 'Approved' ? 'btn-primary' : 'btn-danger';
    document.getElementById('approvalModal').classList.add('open');
}

function rejectRequest(id) {
    approveRequest(id, 'Rejected');
}

function closeModal() {
    document.getElementById('approvalModal').classList.remove('open');
    document.getElementById('notes').value = '';
}
</script>