@model BudgetMasterFinal.Models.Budget
@{
    ViewData["Title"] = "Edit Budget";
    ViewData["PageTitle"] = "Edit Budget";
    Layout = "_DashboardLayout";
    var departments = ViewBag.Departments as List<BudgetMasterFinal.Models.Department> ?? new();
    
    var user = await UserManager.GetUserAsync(User);
    var currency = user?.TenantId.HasValue == true ? await CurrencyService.GetCurrencySymbolAsync(user.TenantId.Value) : "₱";
}

<div class="dash-container">
    <div class="form-card">
        <div class="form-card-header">
            <i class="fa-solid fa-pen"></i>
            <h2>Edit Budget</h2>
        </div>
        <form asp-action="Edit" method="post" class="erp-form">
            @Html.AntiForgeryToken()
            <div class="erp-form-grid">
                <div class="form-group span-2">
                    <label class="form-label">Budget Title</label>
                    <input asp-for="Title" class="form-input" />
                </div>
                <div class="form-group">
                    <label class="form-label">Department</label>
                    <select asp-for="DepartmentId" class="form-input form-select">
                        <option value="">All Departments</option>
                        @foreach (var d in departments)
                        {
                            <option value="@d.Id">@d.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Fiscal Year</label>
                    <input asp-for="FiscalYear" type="number" class="form-input" />
                </div>
                <div class="form-group">
                    <label class="form-label">Quarter</label>
                    <select asp-for="Quarter" class="form-input form-select">
                        <option value="">Annual</option>
                        <option value="Q1">Q1</option>
                        <option value="Q2">Q2</option>
                        <option value="Q3">Q3</option>
                        <option value="Q4">Q4</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Allocated Amount (@currency)</label>
                    <input asp-for="AllocatedAmount" type="number" class="form-input" step="0.01" />
                </div>
                <div class="form-group">
                    <label class="form-label">Status</label>
                    <select asp-for="Status" class="form-input form-select">
                        <option value="Draft">Draft</option>
                        <option value="Active">Active</option>
                        <option value="Closed">Closed</option>
                    </select>
                </div>
                <div class="form-group span-2">
                    <label class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-input form-textarea" rows="3"></textarea>
                </div>
            </div>
            <div class="form-actions">
                <a href="/Budget/Index" class="btn-secondary">Cancel</a>
                <button type="submit" class="btn-primary"><i class="fa-solid fa-save"></i> Update Budget</button>
            </div>
        </form>
    </div>
</div>
