@model List<BudgetMasterFinal.Controllers.DepartmentConsolidation>
@{
    ViewData["Title"] = "Budget Consolidation";
    ViewData["PageTitle"] = "Budget Consolidation";
    Layout = "_DashboardLayout";
    
    int year = ViewBag.Year ?? DateTime.Now.Year;
    decimal totalAllocated = ViewBag.TotalAllocated ?? 0;
    decimal totalUsed = ViewBag.TotalUsed ?? 0;
    decimal totalActualSpend = ViewBag.TotalActualSpend ?? 0;
    decimal totalVariance = ViewBag.TotalVariance ?? 0;
    decimal totalRemaining = ViewBag.TotalRemaining ?? 0;
    int totalPendingRequests = ViewBag.TotalPendingRequests ?? 0;
    int totalApprovedRequests = ViewBag.TotalApprovedRequests ?? 0;
    decimal totalRevenue = ViewBag.TotalRevenue ?? 0;
    decimal totalExpenses = ViewBag.TotalExpenses ?? 0;
    decimal netIncome = ViewBag.NetIncome ?? 0;
    int activeDepartments = ViewBag.ActiveDepartments ?? 0;
    int deptOverBudget = ViewBag.DepartmentsOverBudget ?? 0;
    int deptOnTrack = ViewBag.DepartmentsOnTrack ?? 0;
    int deptAtRisk = ViewBag.DepartmentsAtRisk ?? 0;
    
    var user = await UserManager.GetUserAsync(User);
    var currency = user?.TenantId.HasValue == true ? await CurrencyService.GetCurrencySymbolAsync(user.TenantId.Value) : "₱";
}

<div class="dash-container">
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <form method="get" style="display: flex; align-items: center; gap: 0.75rem;">
            <label style="font-weight: 600; color: var(--text-primary); font-size: 0.9375rem;">Fiscal Year:</label>
            <select name="year" class="form-input" style="width: 120px; padding: 0.5rem 0.75rem;" onchange="this.form.submit()">
                @for (int y = DateTime.Now.Year + 1; y >= DateTime.Now.Year - 3; y--)
                {
                    <option value="@y" selected="@(y == year)">@y</option>
                }
            </select>
        </form>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
            <a href="/Consolidation/DepartmentComparison?year=@year" class="btn-secondary">
                <i class="fa-solid fa-chart-bar"></i> Department Comparison
            </a>
            <a href="/Consolidation/QuarterlyBreakdown?year=@year" class="btn-secondary">
                <i class="fa-solid fa-calendar-days"></i> Quarterly Breakdown
            </a>
            <a href="/Consolidation/TrendAnalysis" class="btn-secondary">
                <i class="fa-solid fa-chart-line"></i> Trend Analysis
            </a>
            <a href="/Consolidation/ForecastIntegration?year=@year" class="btn-secondary">
                <i class="fa-solid fa-crystal-ball"></i> Forecast Integration
            </a>
            <a href="/Consolidation/ExportReport?year=@year" class="btn-primary">
                <i class="fa-solid fa-file-pdf"></i> Export PDF
            </a>
        </div>
    </div>

    <!-- Organization-Wide Financial Summary -->
    <div class="dash-card" style="margin-bottom: 2rem;">
        <div class="dash-card-header">
            <div class="card-title">
                <i class="fa-solid fa-building"></i> Organization-Wide Financial Summary — FY @year
            </div>
        </div>
        <div class="dash-card-body">
            <div class="kpi-grid">
                <div class="kpi-card blue">
                    <div class="kpi-icon"><i class="fa-solid fa-wallet"></i></div>
                    <div class="kpi-info">
                        <div class="kpi-label">Allocated</div>
                        <div class="kpi-value">@currency@totalAllocated.ToString("N0")</div>
                        <div class="kpi-sub">@activeDepartments departments</div>
                    </div>
                </div>
                
                <div class="kpi-card purple">
                    <div class="kpi-icon"><i class="fa-solid fa-check-circle"></i></div>
                    <div class="kpi-info">
                        <div class="kpi-label">Used</div>
                        <div class="kpi-value">@currency@totalUsed.ToString("N0")</div>
                        <div class="kpi-sub">@totalApprovedRequests approved</div>
                    </div>
                </div>
                
                <div class="kpi-card orange">
                    <div class="kpi-icon"><i class="fa-solid fa-receipt"></i></div>
                    <div class="kpi-info">
                        <div class="kpi-label">Actual Spend</div>
                        <div class="kpi-value">@currency@totalActualSpend.ToString("N0")</div>
                        <div class="kpi-sub">Recorded expenses</div>
                    </div>
                </div>
                
                <div class="kpi-card @(totalVariance >= 0 ? "green" : "red")">
                    <div class="kpi-icon"><i class="fa-solid fa-arrows-left-right-to-line"></i></div>
                    <div class="kpi-info">
                        <div class="kpi-label">Variance</div>
                        <div class="kpi-value">@(totalVariance >= 0 ? "+" : "-")@currency@Math.Abs(totalVariance).ToString("N0")</div>
                        <div class="kpi-sub">@(totalVariance >= 0 ? "Under budget" : "Over budget")</div>
                    </div>
                </div>
                
                <div class="kpi-card teal">
                    <div class="kpi-icon"><i class="fa-solid fa-piggy-bank"></i></div>
                    <div class="kpi-info">
                        <div class="kpi-label">Remaining</div>
                        <div class="kpi-value">@currency@totalRemaining.ToString("N0")</div>
                        <div class="kpi-sub">Available budget</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Revenue & Expense Summary -->
    <div class="dash-card" style="margin-bottom: 2rem;">
        <div class="dash-card-header">
            <div class="card-title">
                <i class="fa-solid fa-chart-pie"></i> Revenue & Expense Summary
            </div>
        </div>
        <div class="dash-card-body">
            <div class="kpi-grid">
                <div class="kpi-card green">
                    <div class="kpi-icon"><i class="fa-solid fa-arrow-trend-up"></i></div>
                    <div class="kpi-info">
                        <div class="kpi-label">Revenue</div>
                        <div class="kpi-value">@currency@totalRevenue.ToString("N0")</div>
                        <div class="kpi-sub">Income recorded</div>
                    </div>
                </div>
                
                <div class="kpi-card red">
                    <div class="kpi-icon"><i class="fa-solid fa-arrow-trend-down"></i></div>
                    <div class="kpi-info">
                        <div class="kpi-label">Expenses</div>
                        <div class="kpi-value">@currency@totalExpenses.ToString("N0")</div>
                        <div class="kpi-sub">Costs recorded</div>
                    </div>
                </div>
                
                <div class="kpi-card @(netIncome >= 0 ? "teal" : "red")">
                    <div class="kpi-icon"><i class="fa-solid fa-scale-balanced"></i></div>
                    <div class="kpi-info">
                        <div class="kpi-label">Net Income</div>
                        <div class="kpi-value">@(netIncome >= 0 ? "+" : "-")@currency@Math.Abs(netIncome).ToString("N0")</div>
                        <div class="kpi-sub">Revenue - Expenses</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Department Health Overview -->
    <div class="dash-card" style="margin-bottom: 2rem;">
        <div class="dash-card-header">
            <div class="card-title">
                <i class="fa-solid fa-heartbeat"></i> Department Health Overview
            </div>
        </div>
        <div class="dash-card-body">
            <div class="kpi-grid">
                <div class="kpi-card blue">
                    <div class="kpi-icon"><i class="fa-solid fa-sitemap"></i></div>
                    <div class="kpi-info">
                        <div class="kpi-label">Departments</div>
                        <div class="kpi-value">@activeDepartments</div>
                        <div class="kpi-sub">Total departments</div>
                    </div>
                </div>
                
                <div class="kpi-card green">
                    <div class="kpi-icon"><i class="fa-solid fa-check-double"></i></div>
                    <div class="kpi-info">
                        <div class="kpi-label">On Track</div>
                        <div class="kpi-value">@deptOnTrack</div>
                        <div class="kpi-sub">≤80% budget used</div>
                    </div>
                </div>
                
                <div class="kpi-card orange">
                    <div class="kpi-icon"><i class="fa-solid fa-exclamation-triangle"></i></div>
                    <div class="kpi-info">
                        <div class="kpi-label">At Risk</div>
                        <div class="kpi-value">@deptAtRisk</div>
                        <div class="kpi-sub">80-100% used</div>
                    </div>
                </div>
                
                <div class="kpi-card red">
                    <div class="kpi-icon"><i class="fa-solid fa-circle-exclamation"></i></div>
                    <div class="kpi-info">
                        <div class="kpi-label">Over Budget</div>
                        <div class="kpi-value">@deptOverBudget</div>
                        <div class="kpi-sub">>100% used</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Departmental Breakdown Table -->
    <div class="dash-card">
        <div class="dash-card-header">
            <div class="card-title">
                <i class="fa-solid fa-table"></i> Departmental Budget Breakdown
            </div>
        </div>
        <div class="dash-card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                <table class="dash-table">
                    <thead>
                        <tr>
                            <th style="width: 50px;"></th>
                            <th>Department</th>
                            <th style="text-align: right;">Allocated</th>
                            <th style="text-align: right;">Used</th>
                            <th style="text-align: right;">Actual Spend</th>
                            <th style="text-align: right;">Variance</th>
                            <th style="text-align: right;">Remaining</th>
                            <th style="text-align: center; width: 120px;">Utilization</th>
                            <th style="text-align: center; width: 150px;">Requests</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dept in Model)
                        {
                            var utilization = dept.TotalAllocated > 0 ? (double)(dept.TotalActualSpend / dept.TotalAllocated * 100) : 0;
                            var statusColor = utilization > 100 ? "#ef4444" : utilization > 80 ? "#f97316" : "#10b981";
                            var statusIcon = utilization > 100 ? "fa-circle-exclamation" : utilization > 80 ? "fa-exclamation-triangle" : "fa-check-circle";
                            
                            <tr>
                                <td style="text-align: center;">
                                    <i class="fa-solid @statusIcon" style="color: @statusColor; font-size: 1.125rem;"></i>
                                </td>
                                <td>
                                    <div style="font-weight: 600; color: var(--text-primary); margin-bottom: 0.25rem;">@dept.Department.Name</div>
                                    @if (dept.Budgets.Any())
                                    {
                                        <div style="font-size: 0.75rem; color: var(--text-muted);">@dept.Budgets.Count budget(s)</div>
                                    }
                                </td>
                                <td style="text-align: right; font-weight: 600;">@currency@dept.TotalAllocated.ToString("N0")</td>
                                <td style="text-align: right; font-weight: 600; color: #9333ea;">@currency@dept.TotalUsed.ToString("N0")</td>
                                <td style="text-align: right; font-weight: 700; color: #f97316;">@currency@dept.TotalActualSpend.ToString("N0")</td>
                                <td style="text-align: right; font-weight: 700; color: @(dept.TotalVariance >= 0 ? "#10b981" : "#ef4444");">
                                    @(dept.TotalVariance >= 0 ? "+" : "")@currency@dept.TotalVariance.ToString("N0")
                                </td>
                                <td style="text-align: right; font-weight: 600; color: var(--text-primary);">@currency@dept.TotalRemaining.ToString("N0")</td>
                                <td style="text-align: center;">
                                    <div style="display: flex; flex-direction: column; align-items: center; gap: 0.25rem;">
                                        <div style="width: 80px; height: 6px; background: var(--bg-secondary); border-radius: 3px; overflow: hidden;">
                                            <div style="height: 100%; width: @Math.Min(utilization, 100)%; background: @statusColor; transition: width 0.3s;"></div>
                                        </div>
                                        <span style="font-size: 0.75rem; font-weight: 700; color: @statusColor;">@utilization.ToString("F1")%</span>
                                    </div>
                                </td>
                                <td style="text-align: center;">
                                    <div style="display: flex; gap: 0.375rem; flex-wrap: wrap; justify-content: center;">
                                        @if (dept.PendingRequests > 0)
                                        {
                                            <span style="font-size: 0.7rem; padding: 0.125rem 0.5rem; border-radius: 4px; font-weight: 600; background: #fff7ed; color: #ea580c;">@dept.PendingRequests Pending</span>
                                        }
                                        @if (dept.ApprovedRequests > 0)
                                        {
                                            <span style="font-size: 0.7rem; padding: 0.125rem 0.5rem; border-radius: 4px; font-weight: 600; background: rgba(16, 185, 129, 0.1); color: #059669;">@dept.ApprovedRequests Approved</span>
                                        }
                                        @if (dept.RejectedRequests > 0)
                                        {
                                            <span style="font-size: 0.7rem; padding: 0.125rem 0.5rem; border-radius: 4px; font-weight: 600; background: #fef2f2; color: #dc2626;">@dept.RejectedRequests Rejected</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="2" style="font-weight: 700; color: var(--text-primary);">ORGANIZATION TOTAL</td>
                            <td style="text-align: right; font-weight: 700;">@currency@totalAllocated.ToString("N0")</td>
                            <td style="text-align: right; font-weight: 700; color: #9333ea;">@currency@totalUsed.ToString("N0")</td>
                            <td style="text-align: right; font-weight: 700; color: #f97316;">@currency@totalActualSpend.ToString("N0")</td>
                            <td style="text-align: right; font-weight: 700; color: @(totalVariance >= 0 ? "#10b981" : "#ef4444");">
                                @(totalVariance >= 0 ? "+" : "")@currency@totalVariance.ToString("N0")
                            </td>
                            <td style="text-align: right; font-weight: 700; color: var(--text-primary);">@currency@totalRemaining.ToString("N0")</td>
                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="fa-solid fa-inbox"></i>
                    </div>
                    <h3>No Data Available</h3>
                    <p>No departmental data available for FY @year.</p>
                </div>
            }
        </div>
    </div>
</div>
