@model BudgetMasterFinal.Models.ViewModels.AccountSettingsViewModel
@{
    ViewData["Title"] = "Account Settings";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div class="page-header-content" style="text-align: center;">
        <div>
            <h1 class="page-title">
                <i class="fa-solid fa-user-gear"></i> Account Settings
            </h1>
            <p class="page-subtitle">Manage your personal account information and security settings</p>
        </div>
    </div>
</div>

<div class="settings-container">
    <!-- Profile Information Card -->
    <div class="settings-card">
        <div class="settings-card-header">
            <div class="settings-card-title">
                <i class="fa-solid fa-user"></i>
                <h2>Profile Information</h2>
            </div>
            <p class="settings-card-subtitle">Update your personal information</p>
        </div>
        <div class="settings-card-body">
            <form id="profileForm">
                @Html.AntiForgeryToken()
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fa-solid fa-user"></i> First Name
                        </label>
                        <input type="text" id="firstName" class="form-input" value="@Model.FirstName" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fa-solid fa-user"></i> Last Name
                        </label>
                        <input type="text" id="lastName" class="form-input" value="@Model.LastName" required />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-envelope"></i> Email Address
                    </label>
                    <input type="email" class="form-input" value="@Model.Email" readonly style="background: #f3f4f6; cursor: not-allowed;" />
                    <small class="form-hint">Email address cannot be changed. Contact your administrator if needed.</small>
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-shield-halved"></i> Role
                    </label>
                    <input type="text" class="form-input" value="@Model.Role" readonly style="background: #f3f4f6; cursor: not-allowed;" />
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn-primary">
                        <i class="fa-solid fa-save"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Security Settings Card -->
    <div class="settings-card">
        <div class="settings-card-header">
            <div class="settings-card-title">
                <i class="fa-solid fa-lock"></i>
                <h2>Security Settings</h2>
            </div>
            <p class="settings-card-subtitle">Manage your password and security preferences</p>
        </div>
        <div class="settings-card-body">
            <form id="passwordForm">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-key"></i> Current Password
                    </label>
                    <div class="input-wrapper">
                        <input type="password" id="currentPassword" class="form-input" placeholder="Enter current password" required />
                        <button type="button" class="input-toggle" onclick="togglePasswordVisibility('currentPassword', this)">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-lock"></i> New Password
                    </label>
                    <div class="input-wrapper">
                        <input type="password" id="newPassword" class="form-input" placeholder="Enter new password" required />
                        <button type="button" class="input-toggle" onclick="togglePasswordVisibility('newPassword', this)">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                    <small class="form-hint">Password must be at least 6 characters and contain a number.</small>
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-lock"></i> Confirm New Password
                    </label>
                    <div class="input-wrapper">
                        <input type="password" id="confirmPassword" class="form-input" placeholder="Confirm new password" required />
                        <button type="button" class="input-toggle" onclick="togglePasswordVisibility('confirmPassword', this)">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn-primary">
                        <i class="fa-solid fa-shield-halved"></i> Change Password
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- 2FA Settings Card -->
    <div class="settings-card">
        <div class="settings-card-header">
            <div class="settings-card-title">
                <i class="fa-solid fa-mobile-screen-button"></i>
                <h2>2 Factor Auth</h2>
            </div>
            <p class="settings-card-subtitle">Enhanced account protection</p>
        </div>
        <div class="settings-card-body">
            <div id="twofa-disabled" class="twofa-state">
                <div class="twofa-icon-container">
                    <div class="twofa-icon disabled">
                        <i class="fa-solid fa-lock"></i>
                    </div>
                </div>
                <h3 class="twofa-status">Disabled</h3>
                <p class="twofa-description">Add an extra layer of security to your account.</p>
                <button type="button" class="btn-enable-2fa" onclick="enable2FA()">
                    <i class="fa-solid fa-shield-halved"></i> Enable 2FA
                </button>
            </div>

            <div id="twofa-setup" class="twofa-state" style="display: none;">
                <div class="twofa-qr-container">
                    <div id="qrcode"></div>
                    <p class="twofa-scan-text">Scan QR Code</p>
                </div>

                <div class="twofa-setup-guide">
                    <h4 class="setup-guide-title">Setup Guide</h4>
                    <ol class="setup-steps">
                        <li>Download <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2" target="_blank">Google Authenticator</a> or <a href="https://www.microsoft.com/en-us/security/mobile-authenticator-app" target="_blank">Microsoft Authenticator</a>.</li>
                        <li>Scan the QR code or enter the key manually.</li>
                        <li>Enter the 6-digit verification code below.</li>
                    </ol>
                </div>

                <div class="twofa-manual-key">
                    <p class="manual-key-label">OR ENTER MANUALLY</p>
                    <div class="manual-key-box">
                        <span id="manualKey">7NLH KZ4K TA25 3L5E Q3TQ JCSR 3FRX EHF6</span>
                        <button type="button" class="btn-copy" onclick="copyManualKey()">
                            <i class="fa-solid fa-copy"></i>
                        </button>
                    </div>
                </div>

                <div class="twofa-verify-code">
                    <div class="code-input-container">
                        <input type="text" maxlength="1" class="code-digit" data-index="0" />
                        <input type="text" maxlength="1" class="code-digit" data-index="1" />
                        <input type="text" maxlength="1" class="code-digit" data-index="2" />
                        <input type="text" maxlength="1" class="code-digit" data-index="3" />
                        <input type="text" maxlength="1" class="code-digit" data-index="4" />
                        <input type="text" maxlength="1" class="code-digit" data-index="5" />
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn-primary" onclick="verifyCode()">
                        <i class="fa-solid fa-check"></i> Verify Code
                    </button>
                    <button type="button" class="btn-secondary" onclick="cancel2FA()">
                        <i class="fa-solid fa-times"></i> Cancel
                    </button>
                </div>
            </div>

            <div id="twofa-enabled" class="twofa-state" style="display: none;">
                <div class="twofa-icon-container">
                    <div class="twofa-icon enabled">
                        <i class="fa-solid fa-check"></i>
                    </div>
                </div>
                <h3 class="twofa-status">Enabled</h3>
                <p class="twofa-description">Your account is protected with two-factor authentication.</p>
                <button type="button" class="btn-danger" onclick="disable2FA()">
                    <i class="fa-solid fa-shield-xmark"></i> Disable 2FA
                </button>
            </div>
        </div>
    </div>

    <!-- Session Management Card -->
    <div class="settings-card">
        <div class="settings-card-header">
            <div class="settings-card-title">
                <i class="fa-solid fa-clock"></i>
                <h2>Session Management</h2>
            </div>
            <p class="settings-card-subtitle">Manage your active sessions and login history</p>
        </div>
        <div class="settings-card-body">
            <div class="session-info">
                <div class="info-row">
                    <div class="info-label">
                        <i class="fa-solid fa-calendar-check"></i> Account Created
                    </div>
                    <div class="info-value">@Model.CreatedAt.ToString("MMMM dd, yyyy")</div>
                </div>
                <div class="info-row">
                    <div class="info-label">
                        <i class="fa-solid fa-clock"></i> Last Login
                    </div>
                    <div class="info-value">
                        @if (Model.LastLoginAt.HasValue)
                        {
                            @Model.LastLoginAt.Value.ToString("MMMM dd, yyyy hh:mm tt")
                        }
                        else
                        {
                            <span>Never</span>
                        }
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-label">
                        <i class="fa-solid fa-circle-check"></i> Account Status
                    </div>
                    <div class="info-value">
                        @if (Model.IsActive)
                        {
                            <span class="badge badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-danger">Inactive</span>
                        }
                    </div>
                </div>
            </div>
            <div class="form-actions" style="margin-top: 24px;">
                <button type="button" class="btn-danger" onclick="terminateAllSessions()">
                    <i class="fa-solid fa-right-from-bracket"></i> Terminate All Sessions
                </button>
                <a href="/AccountSettings/ActivityLog" class="btn-secondary">
                    <i class="fa-solid fa-list"></i> View Activity Log
                </a>
            </div>
        </div>
    </div>
</div>

