@model dynamic
@{
    ViewData["Title"] = "Archive Statistics";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header" style="text-align: center;">
    <div class="page-header-content">
        <div>
            <h1 class="page-title">
                <i class="fa-solid fa-chart-bar"></i> Archive Statistics
            </h1>
            <p class="page-subtitle">Overview of archived items and trends</p>
        </div>
    </div>
</div>

<div class="stats-container">
    <!-- Summary Cards -->
    <div class="stats-summary">
        <div class="stat-card">
            <div class="stat-icon" style="background: #dbeafe; color: #1e40af;">
                <i class="fa-solid fa-box-archive"></i>
            </div>
            <div class="stat-content">
                <h3>Total Archived</h3>
                <p class="stat-value">@Model.TotalArchived</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon" style="background: #dcfce7; color: #166534;">
                <i class="fa-solid fa-layer-group"></i>
            </div>
            <div class="stat-content">
                <h3>Entity Types</h3>
                <p class="stat-value">@Model.ByEntityType.Count</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon" style="background: #fef3c7; color: #92400e;">
                <i class="fa-solid fa-clock"></i>
            </div>
            <div class="stat-content">
                <h3>Recent (Last 7 Days)</h3>
                <p class="stat-value">@Model.RecentArchives.Count</p>
            </div>
        </div>
    </div>

    <!-- By Entity Type -->
    <div class="stats-section">
        <div class="section-header">
            <h2><i class="fa-solid fa-chart-pie"></i> Archives by Entity Type</h2>
        </div>
        <div class="entity-stats">
            @foreach (var item in Model.ByEntityType)
            {
                var percentage = Model.TotalArchived > 0 ? (item.Count * 100.0 / Model.TotalArchived) : 0;
                <div class="entity-stat-item">
                    <div class="entity-stat-header">
                        <span class="entity-name">@item.EntityType</span>
                        <span class="entity-count">@item.Count items</span>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: @percentage%"></div>
                    </div>
                    <span class="entity-percentage">@percentage.ToString("F1")%</span>
                </div>
            }
        </div>
    </div>

    <!-- Recent Archives -->
    <div class="stats-section">
        <div class="section-header">
            <h2><i class="fa-solid fa-clock-rotate-left"></i> Recent Archives</h2>
            <a href="@Url.Action("Index", "Archive")" class="btn-link">View All</a>
        </div>
        <div class="recent-list">
            @if (Model.RecentArchives.Count == 0)
            {
                <div class="empty-state">
                    <i class="fa-solid fa-inbox"></i>
                    <p>No recent archives</p>
                </div>
            }
            else
            {
                @foreach (var item in Model.RecentArchives)
                {
                    <div class="recent-item">
                        <div class="recent-icon">
                            @switch (item.EntityType)
                            {
                                case "ApplicationUser":
                                    <i class="fa-solid fa-user"></i>
                                    break;
                                case "Department":
                                    <i class="fa-solid fa-building"></i>
                                    break;
                                case "Budget":
                                    <i class="fa-solid fa-sack-dollar"></i>
                                    break;
                                case "BudgetRequest":
                                    <i class="fa-solid fa-file-invoice-dollar"></i>
                                    break;
                                case "Forecast":
                                    <i class="fa-solid fa-chart-line"></i>
                                    break;
                                case "ScenarioPlan":
                                    <i class="fa-solid fa-diagram-project"></i>
                                    break;
                                case "ActualTransaction":
                                    <i class="fa-solid fa-receipt"></i>
                                    break;
                                case "Notification":
                                    <i class="fa-solid fa-bell"></i>
                                    break;
                                case "Subscription":
                                    <i class="fa-solid fa-credit-card"></i>
                                    break;
                                case "SubscriptionPlan":
                                    <i class="fa-solid fa-layer-group"></i>
                                    break;
                                case "BillingTransaction":
                                    <i class="fa-solid fa-money-bill-transfer"></i>
                                    break;
                                case "BillingDiscount":
                                    <i class="fa-solid fa-percent"></i>
                                    break;
                                case "Tenant":
                                    <i class="fa-solid fa-building-user"></i>
                                    break;
                                default:
                                    <i class="fa-solid fa-box"></i>
                                    break;
                            }
                        </div>
                        <div class="recent-info">
                            <h4>@item.EntityName</h4>
                            <p>
                                <span class="entity-badge">@item.EntityType</span>
                                <span class="recent-date">@item.ArchivedAt.ToString("MMM dd, yyyy")</span>
                            </p>
                        </div>
                        <a href="@Url.Action("Details", new { id = item.Id })" class="btn-view">
                            <i class="fa-solid fa-eye"></i>
                        </a>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Monthly Trend -->
    <div class="stats-section">
        <div class="section-header">
            <h2><i class="fa-solid fa-chart-line"></i> Archive Trend (Last 12 Months)</h2>
        </div>
        <div class="trend-chart">
            @if (Model.ByMonth.Count == 0)
            {
                <div class="empty-state">
                    <i class="fa-solid fa-chart-simple"></i>
                    <p>No data available</p>
                </div>
            }
            else
            {
                var byMonthList = (IEnumerable<dynamic>)Model.ByMonth;
                var maxCount = byMonthList.Max(m => (int)m.Count);
                <div class="chart-bars">
                    @foreach (var month in byMonthList.OrderBy(m => (string)m.Month))
                    {
                        var height = maxCount > 0 ? (month.Count * 100.0 / maxCount) : 0;
                        <div class="chart-bar-container">
                            <div class="chart-bar" style="height: @height%" title="@month.Count items">
                                <span class="bar-value">@month.Count</span>
                            </div>
                            <span class="bar-label">@month.Month</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
<style>
.stats-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 24px;
}

.stats-summary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 32px;
}

.stat-card {
    background: white;
    border-radius: 12px;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.stat-icon {
    width: 64px;
    height: 64px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
}

.stat-content h3 {
    margin: 0 0 8px 0;
    font-size: 14px;
    color: #64748b;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.stat-value {
    margin: 0;
    font-size: 32px;
    font-weight: 700;
    color: #1e293b;
}

.stats-section {
    background: white;
    border-radius: 12px;
    padding: 32px;
    margin-bottom: 24px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 2px solid #e2e8f0;
}

.section-header h2 {
    margin: 0;
    font-size: 22px;
    color: #1e293b;
    display: flex;
    align-items: center;
    gap: 10px;
}

.btn-link {
    color: #1e3a5f;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
}

.btn-link:hover {
    color: #10b981;
}

.entity-stats {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.entity-stat-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    align-items: center;
}

.entity-stat-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
}

.entity-name {
    font-weight: 600;
    color: #1e293b;
}

.entity-count {
    font-size: 14px;
    color: #64748b;
}

.progress-bar {
    height: 12px;
    background: #f1f5f9;
    border-radius: 6px;
    overflow: hidden;
}

.progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #1e3a5f, #10b981);
    border-radius: 6px;
    transition: width 0.3s ease;
}

.entity-percentage {
    font-weight: 600;
    color: #1e3a5f;
    min-width: 60px;
    text-align: right;
}

.recent-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.recent-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background: #f8fafc;
    border-radius: 8px;
    transition: all 0.2s;
}

.recent-item:hover {
    background: #f1f5f9;
}

.recent-icon {
    width: 48px;
    height: 48px;
    background: white;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    color: #1e3a5f;
}

.recent-info {
    flex: 1;
}

.recent-info h4 {
    margin: 0 0 6px 0;
    font-size: 16px;
    color: #1e293b;
}

.recent-info p {
    margin: 0;
    display: flex;
    gap: 12px;
    align-items: center;
}

.entity-badge {
    display: inline-block;
    padding: 4px 10px;
    background: #e0f2fe;
    color: #0369a1;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
}

.recent-date {
    font-size: 14px;
    color: #64748b;
}

.btn-view {
    width: 40px;
    height: 40px;
    background: #1e3a5f;
    color: white;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: all 0.2s;
}

.btn-view:hover {
    background: #10b981;
}

.trend-chart {
    min-height: 300px;
}

.chart-bars {
    display: flex;
    align-items: flex-end;
    gap: 16px;
    height: 250px;
    padding: 20px 0;
}

.chart-bar-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
}

.chart-bar {
    width: 100%;
    background: linear-gradient(180deg, #1e3a5f, #10b981);
    border-radius: 8px 8px 0 0;
    position: relative;
    min-height: 20px;
    transition: all 0.3s ease;
    cursor: pointer;
}

.chart-bar:hover {
    opacity: 0.8;
}

.bar-value {
    position: absolute;
    top: -24px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    font-weight: 600;
    color: #1e293b;
}

.bar-label {
    font-size: 12px;
    color: #64748b;
    text-align: center;
}

.empty-state {
    text-align: center;
    padding: 60px 20px;
    color: #94a3b8;
}

.empty-state i {
    font-size: 48px;
    margin-bottom: 12px;
}

.empty-state p {
    margin: 0;
    font-size: 16px;
}

@@media (max-width: 768px) {
    .stats-summary {
        grid-template-columns: 1fr;
    }
    
    .chart-bars {
        gap: 8px;
    }
    
    .bar-label {
        font-size: 10px;
    }
}
</style>
}
