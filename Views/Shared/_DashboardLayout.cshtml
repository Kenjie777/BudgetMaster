@using Microsoft.AspNetCore.Identity
@inject SignInManager<BudgetMasterFinal.Models.ApplicationUser> SignInManager
@inject UserManager<BudgetMasterFinal.Models.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BudgetMaster</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body class="dashboard-body">

@{
    var currentUser = await UserManager.GetUserAsync(User);
    var isSuperAdmin = currentUser?.Role == "SuperAdmin";
}

<!-- Sidebar -->
<aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
        <img src="~/images/BudgetMasterLogo1.png" alt="BudgetMaster" class="sidebar-logo" id="sidebarLogo" />
        <button class="sidebar-toggle-btn" id="sidebarToggle"><i class="fa-solid fa-bars"></i></button>
    </div>

    <nav class="sidebar-nav">
        @if (isSuperAdmin)
        {
            <div class="nav-section-label">System Management</div>
            <a href="/Dashboard/SuperAdmin" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "SuperAdmin" ? "active" : "")"><i class="fa-solid fa-gauge-high"></i><span>Dashboard</span></a>
            <a href="/SuperAdmin/Tenants" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "SuperAdmin" && ViewContext.RouteData.Values["action"]?.ToString() == "Tenants" ? "active" : "")"><i class="fa-solid fa-building"></i><span>Companies</span></a>
            <a href="/SuperAdminReports/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "SuperAdminReports" ? "active" : "")"><i class="fa-solid fa-chart-bar"></i><span>Platform Reports</span></a>
            <div class="nav-section-label">Billing & Revenue</div>
            <a href="/Billing/Dashboard" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Billing" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"><i class="fa-solid fa-chart-line"></i><span>Revenue Dashboard</span></a>
            <a href="/Billing/Subscriptions" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Billing" && ViewContext.RouteData.Values["action"]?.ToString() == "Subscriptions" ? "active" : "")"><i class="fa-solid fa-credit-card"></i><span>Subscriptions</span></a>
            <a href="/Billing/Plans" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Billing" && ViewContext.RouteData.Values["action"]?.ToString() == "Plans" ? "active" : "")"><i class="fa-solid fa-layer-group"></i><span>Subscription Plans</span></a>
            @* <a href="/Billing/Transactions" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Billing" && ViewContext.RouteData.Values["action"]?.ToString() == "Transactions" ? "active" : "")"><i class="fa-solid fa-receipt"></i><span>Transactions</span></a> *@
            @* <a href="/Billing/Credits" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Billing" && ViewContext.RouteData.Values["action"]?.ToString() == "Credits" ? "active" : "")"><i class="fa-solid fa-coins"></i><span>Credits</span></a> *@
            @* <a href="/Billing/Discounts" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Billing" && ViewContext.RouteData.Values["action"]?.ToString() == "Discounts" ? "active" : "")"><i class="fa-solid fa-percent"></i><span>Discounts</span></a> *@
            <div class="nav-section-label">System</div>
            <a href="/Archive/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Archive" ? "active" : "")"><i class="fa-solid fa-box-archive"></i><span>Archived Items</span></a>
            <a href="/SuperAdmin/AuditLogs" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "AuditLogs" ? "active" : "")"><i class="fa-solid fa-scroll"></i><span>Audit Logs</span></a>
            <a href="/SuperAdmin/Settings" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Settings" ? "active" : "")"><i class="fa-solid fa-gear"></i><span>System Settings</span></a>
        }
        else if (currentUser?.Role == "Tenant")
        {
            <div class="nav-section-label">Overview</div>
            <a href="/Dashboard/Admin" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Admin" ? "active" : "")"><i class="fa-solid fa-gauge-high"></i><span>Dashboard</span></a>
            <div class="nav-section-label">User Management</div>
            <a href="/UserManagement/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "UserManagement" ? "active" : "")"><i class="fa-solid fa-users"></i><span>Users & Roles</span></a>
            <a href="/Department/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Department" ? "active" : "")"><i class="fa-solid fa-sitemap"></i><span>Departments</span></a>
            <div class="nav-section-label">Organization Configuration</div>
            <a href="/Organization/Profile" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Organization" && ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")"><i class="fa-solid fa-building"></i><span>Company Profile</span></a>
            <a href="/Organization/Settings" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Organization" && ViewContext.RouteData.Values["action"]?.ToString() == "Settings" ? "active" : "")"><i class="fa-solid fa-cog"></i><span>General Settings</span></a>
            <a href="/Organization/FiscalYear" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Organization" && ViewContext.RouteData.Values["action"]?.ToString() == "FiscalYear" ? "active" : "")"><i class="fa-solid fa-calendar-alt"></i><span>Fiscal Year Setup</span></a>
            <div class="nav-section-label">Workflow Configuration</div>
            <a href="/Organization/Policies" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Organization" && ViewContext.RouteData.Values["action"]?.ToString() == "Policies" ? "active" : "")"><i class="fa-solid fa-shield-alt"></i><span>Approval Workflows</span></a>
            <div class="nav-section-label">System Monitoring</div>
            <a href="/Archive/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Archive" ? "active" : "")"><i class="fa-solid fa-box-archive"></i><span>Archived Items</span></a>
            <a href="/Organization/AuditLog" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Organization" && ViewContext.RouteData.Values["action"]?.ToString() == "AuditLog" ? "active" : "")"><i class="fa-solid fa-history"></i><span>Audit Logs</span></a>
        }
        else if (currentUser?.Role == "FinanceManager")
        {
            <div class="nav-section-label">Financial Control Center</div>
            <a href="/Dashboard/FinanceManager" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "FinanceManager" ? "active" : "")"><i class="fa-solid fa-gauge-high"></i><span>Dashboard</span></a>
            
            <div class="nav-section-label">Budget Management</div>
            <a href="/Budget/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Budget" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"><i class="fa-solid fa-wallet"></i><span>Budget Allocation</span></a>
            <a href="/Budget/FinancialValidation" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "FinancialValidation" ? "active" : "")"><i class="fa-solid fa-file-invoice-dollar"></i><span>Financial Validation</span></a>
            <a href="/Budget/AllRequests" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "AllRequests" ? "active" : "")"><i class="fa-solid fa-list-check"></i><span>All Requests (Report)</span></a>
            
            <div class="nav-section-label">Financial Planning</div>
            <a href="/Forecast/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Forecast" ? "active" : "")"><i class="fa-solid fa-chart-line"></i><span>Financial Forecasting</span></a>
            <a href="/Scenario/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Scenario" ? "active" : "")"><i class="fa-solid fa-diagram-project"></i><span>Scenario Planning</span></a>
            
            <div class="nav-section-label">Financial Analysis</div>
            <a href="/Variance/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Variance" ? "active" : "")"><i class="fa-solid fa-arrows-left-right-to-line"></i><span>Variance Analysis</span></a>
            <a href="/Consolidation/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Consolidation" ? "active" : "")"><i class="fa-solid fa-layer-group"></i><span>Budget Consolidation</span></a>
            
            <div class="nav-section-label">Financial Reporting</div>
            <a href="/Budget/Reports" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Reports" ? "active" : "")"><i class="fa-solid fa-chart-bar"></i><span>Financial Reports</span></a>
            <a href="/Variance/Analytics" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Analytics" ? "active" : "")"><i class="fa-solid fa-magnifying-glass-chart"></i><span>Performance Analytics</span></a>
        }
        else if (currentUser?.Role == "Accountant")
        {
            <div class="nav-section-label">Accounting</div>
            <a href="/Dashboard/Accountant" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Accountant" ? "active" : "")"><i class="fa-solid fa-gauge-high"></i><span>Dashboard</span></a>
            <div class="nav-section-label">Ledger</div>
            <a href="/Variance/Transactions" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Transactions" ? "active" : "")"><i class="fa-solid fa-receipt"></i><span>Record Transactions</span></a>
            <a href="/Variance/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Variance" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"><i class="fa-solid fa-arrows-left-right-to-line"></i><span>Variance Reports</span></a>
            <a href="/Budget/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Budget" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"><i class="fa-solid fa-wallet"></i><span>View Budgets</span></a>
        }
        else if (currentUser?.Role == "DepartmentHead")
        {
            <div class="nav-section-label">Department Operations</div>
            <a href="/Dashboard/DepartmentHead" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["action"]?.ToString() == "DepartmentHead" ? "active" : "")"><i class="fa-solid fa-gauge-high"></i><span>Dashboard</span></a>
            
            <div class="nav-section-label">Operational Approval</div>
            <a href="/Budget/DepartmentRequests" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "DepartmentRequests" ? "active" : "")"><i class="fa-solid fa-file-invoice-dollar"></i><span>Budget Requests</span></a>
            <a href="/Budget/RequestApproval" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "RequestApproval" ? "active" : "")"><i class="fa-solid fa-check-circle"></i><span>Approval Workflow</span></a>
            <a href="/Budget/CreateRequest" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "CreateRequest" ? "active" : "")"><i class="fa-solid fa-plus-circle"></i><span>Submit Request</span></a>
            
            <div class="nav-section-label">Department Management</div>
            <a href="/Budget/DepartmentBudgets" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "DepartmentBudgets" ? "active" : "")"><i class="fa-solid fa-wallet"></i><span>Department Budgets</span></a>
            <a href="/Budget/TeamActivity" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "TeamActivity" ? "active" : "")"><i class="fa-solid fa-users"></i><span>Team Activity</span></a>
        }
        else if (currentUser?.Role == "Employee")
        {
            <div class="nav-section-label">My Workspace</div>
            <a href="/Dashboard/Employee" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Employee" ? "active" : "")"><i class="fa-solid fa-gauge-high"></i><span>Dashboard</span></a>
            <div class="nav-section-label">Requests</div>
            <a href="/Budget/MyRequests" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "MyRequests" ? "active" : "")"><i class="fa-solid fa-file-invoice-dollar"></i><span>My Requests</span></a>
            <a href="/Budget/CreateRequest" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "CreateRequest" ? "active" : "")"><i class="fa-solid fa-plus-circle"></i><span>New Request</span></a>
        }
        else if (currentUser?.Role == "Auditor")
        {
            <div class="nav-section-label">Audit & Compliance</div>
            <a href="/Dashboard/Auditor" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Auditor" ? "active" : "")"><i class="fa-solid fa-gauge-high"></i><span>Dashboard</span></a>
            <div class="nav-section-label">Review</div>
            <a href="/Budget/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Budget" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"><i class="fa-solid fa-wallet"></i><span>Review Budgets</span></a>
            <a href="/Variance/Transactions" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Transactions" ? "active" : "")"><i class="fa-solid fa-receipt"></i><span>Transactions</span></a>
            <a href="/Variance/Index" class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Variance" ? "active" : "")"><i class="fa-solid fa-arrows-left-right-to-line"></i><span>Variance Reports</span></a>
            <a href="/SuperAdmin/AuditLogs" class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "AuditLogs" ? "active" : "")"><i class="fa-solid fa-scroll"></i><span>Audit Logs</span></a>
        }
    </nav>
</aside>

<!-- Main content -->
<div class="main-wrapper" id="mainWrapper">
    <!-- Topbar -->
    <header class="topbar">
        <div class="topbar-left">
            <button class="topbar-menu-btn" id="menuToggle"><i class="fa-solid fa-bars"></i></button>
            <div class="topbar-title">@ViewData["PageTitle"]</div>
        </div>
        <div class="topbar-right">
            <div class="topbar-notif" id="notifBtn">
                <i class="fa-solid fa-bell"></i>
                <span class="notif-badge" id="notifBadge" style="display: none;">0</span>
            </div>
            
            <!-- Notification Modal -->
            <div class="notification-modal" id="notificationModal" style="display: none;">
                <div class="notif-modal-header">
                    <h3>Notifications</h3>
                    <div class="notif-modal-actions">
                        <button class="notif-action-btn" id="markAllReadBtn" title="Mark all as read">
                            <i class="fa-solid fa-check-double"></i>
                        </button>
                        <button class="notif-action-btn" id="clearReadBtn" title="Clear read notifications">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </div>
                <div class="notif-modal-body" id="notificationList">
                    <div class="notif-loading">
                        <i class="fa-solid fa-spinner fa-spin"></i> Loading notifications...
                    </div>
                </div>
            </div>
            
            <div class="topbar-user" id="userDropdownBtn">
                <div class="user-avatar">@(currentUser?.FirstName?.Substring(0, 1))@(currentUser?.LastName?.Substring(0, 1))</div>
                <div class="user-info">
                    <span class="user-name">@currentUser?.FullName</span>
                    <span class="user-role">@currentUser?.Role</span>
                </div>
                <i class="fa-solid fa-chevron-down"></i>
            </div>
            <div class="user-dropdown" id="userDropdown">
                <div class="dropdown-header">
                    <div class="dh-name">@currentUser?.FullName</div>
                    <div class="dh-email">@currentUser?.Email</div>
                </div>
                <a href="/AccountSettings/Index" class="dropdown-item">
                    <i class="fa-solid fa-user-gear"></i> Account Settings
                </a>
                <div class="dropdown-divider"></div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="dropdown-item logout-item">
                        <i class="fa-solid fa-right-from-bracket"></i> Sign Out
                    </button>
                </form>
            </div>
        </div>
    </header>

    <!-- Page content -->
    <main class="page-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert-toast success" id="toastAlert">
                <i class="fa-solid fa-circle-check"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-toast error" id="toastAlert">
                <i class="fa-solid fa-circle-xmark"></i> @TempData["Error"]
            </div>
        }
        @RenderBody()
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/dashboard.js" asp-append-version="true"></script>
<script src="~/js/notifications.js" asp-append-version="true"></script>
@RenderSection("Scripts", required: false)
</body>
</html>