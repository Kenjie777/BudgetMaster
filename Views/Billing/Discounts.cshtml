@model IEnumerable<BudgetMasterFinal.Models.BillingDiscount>
@{
    ViewData["Title"] = "Discount Management";
    ViewData["PageTitle"] = "Discount Management";
    Layout = "_DashboardLayout";
}

<div class="dash-container">
    <div class="page-actions">
        <a href="@Url.Action("CreateDiscount")" class="btn-primary">
            <i class="fa-solid fa-plus"></i> Create Discount
        </a>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card blue">
            <div class="kpi-icon"><i class="fa-solid fa-tags"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">Total Discounts</div>
                <div class="kpi-value">@Model.Count()</div>
                <div class="kpi-sub">All discount codes</div>
            </div>
        </div>
        <div class="kpi-card green">
            <div class="kpi-icon"><i class="fa-solid fa-check-circle"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">Active Discounts</div>
                <div class="kpi-value">@Model.Count(d => d.Status == "Active")</div>
                <div class="kpi-sub">Currently available</div>
            </div>
        </div>
        <div class="kpi-card orange">
            <div class="kpi-icon"><i class="fa-solid fa-chart-line"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">Total Usage</div>
                <div class="kpi-value">@Model.Sum(d => d.CurrentUsageCount)</div>
                <div class="kpi-sub">Times used</div>
            </div>
        </div>
        <div class="kpi-card purple">
            <div class="kpi-icon"><i class="fa-solid fa-clock"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">Expiring Soon</div>
                <div class="kpi-value">@Model.Count(d => d.ValidUntil.HasValue && d.ValidUntil.Value <= DateTime.UtcNow.AddDays(7) && d.Status == "Active")</div>
                <div class="kpi-sub">Within 7 days</div>
            </div>
        </div>
    </div>

    <div class="dash-card">
        <div class="card-header">
            <div class="card-title"><i class="fa-solid fa-tags"></i> Discount Codes</div>
            <div class="card-filters">
                <select class="filter-input" onchange="filterDiscounts(this.value)">
                    <option value="">All Status</option>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                    <option value="Expired">Expired</option>
                </select>
                <input type="text" class="filter-input" placeholder="Search codes..." onkeyup="searchDiscounts(this.value)">
            </div>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="discount-grid">
                    @foreach (var discount in Model.OrderByDescending(d => d.CreatedAt))
                    {
                        <div class="discount-card" data-status="@discount.Status.ToLower()" data-code="@discount.Code.ToLower()">
                            <div class="discount-header">
                                <div class="discount-name">@discount.Name</div>
                                <div class="discount-status">
                                    <span class="status-badge @GetStatusClass(discount.Status)">@discount.Status</span>
                                </div>
                            </div>
                            
                            <div class="discount-code">
                                <i class="fa-solid fa-tag"></i>
                                <span class="code-text">@discount.Code</span>
                                <button class="btn-copy" onclick="copyCode('@discount.Code')" title="Copy code">
                                    <i class="fa-solid fa-copy"></i>
                                </button>
                            </div>

                            @if (!string.IsNullOrEmpty(discount.Description))
                            {
                                <div class="discount-desc">@discount.Description</div>
                            }

                            <div class="discount-details">
                                <div class="detail-row">
                                    <span class="detail-label">Type:</span>
                                    <span class="detail-value">
                                        @if (discount.DiscountType == "Percentage")
                                        {
                                            <text>@discount.DiscountValue% Off</text>
                                        }
                                        else if (discount.DiscountType == "Fixed")
                                        {
                                            <text>₱@discount.DiscountValue.ToString("N0") Off</text>
                                        }
                                        else
                                        {
                                            <text>@discount.DiscountType</text>
                                        }
                                    </span>
                                </div>
                                
                                @if (discount.ValidFrom.HasValue || discount.ValidUntil.HasValue)
                                {
                                    <div class="detail-row">
                                        <span class="detail-label">Valid:</span>
                                        <span class="detail-value">
                                            @if (discount.ValidFrom.HasValue && discount.ValidUntil.HasValue)
                                            {
                                                <text>@discount.ValidFrom.Value.ToString("MMM dd") - @discount.ValidUntil.Value.ToString("MMM dd, yyyy")</text>
                                            }
                                            else if (discount.ValidUntil.HasValue)
                                            {
                                                <text>Until @discount.ValidUntil.Value.ToString("MMM dd, yyyy")</text>
                                            }
                                            else if (discount.ValidFrom.HasValue)
                                            {
                                                <text>From @discount.ValidFrom.Value.ToString("MMM dd, yyyy")</text>
                                            }
                                        </span>
                                    </div>
                                }

                                <div class="detail-row">
                                    <span class="detail-label">Usage:</span>
                                    <span class="detail-value">
                                        @discount.CurrentUsageCount
                                        @if (discount.MaxUsageCount.HasValue)
                                        {
                                            <text> / @discount.MaxUsageCount</text>
                                        }
                                        else
                                        {
                                            <text> / Unlimited</text>
                                        }
                                    </span>
                                </div>

                                @if (discount.MinimumOrderAmount.HasValue)
                                {
                                    <div class="detail-row">
                                        <span class="detail-label">Min Order:</span>
                                        <span class="detail-value">₱@discount.MinimumOrderAmount.Value.ToString("N0")</span>
                                    </div>
                                }

                                <div class="detail-row">
                                    <span class="detail-label">Applies To:</span>
                                    <span class="detail-value">@GetApplicableToText(discount.ApplicableTo)</span>
                                </div>
                            </div>

                            <div class="discount-actions">
                                <a href="@Url.Action("EditDiscount", new { id = discount.Id })" class="btn-icon" title="Edit">
                                    <i class="fa-solid fa-edit"></i>
                                </a>
                                
                                @if (discount.Status == "Active")
                                {
                                    <form method="post" action="@Url.Action("DeactivateDiscount", new { id = discount.Id })" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-icon warning" title="Deactivate" onclick="return confirm('Deactivate this discount?')">
                                            <i class="fa-solid fa-pause"></i>
                                        </button>
                                    </form>
                                }
                                else if (discount.Status == "Inactive")
                                {
                                    <form method="post" action="@Url.Action("ActivateDiscount", new { id = discount.Id })" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-icon" title="Activate" onclick="return confirm('Activate this discount?')">
                                            <i class="fa-solid fa-play"></i>
                                        </button>
                                    </form>
                                }

                                <button class="btn-icon" onclick="viewUsageDetails(@discount.Id)" title="View Usage">
                                    <i class="fa-solid fa-chart-bar"></i>
                                </button>
                            </div>

                            @if (discount.ValidUntil.HasValue && discount.ValidUntil.Value <= DateTime.UtcNow.AddDays(7) && discount.Status == "Active")
                            {
                                <div class="expiry-warning">
                                    <i class="fa-solid fa-exclamation-triangle"></i>
                                    Expires in @((discount.ValidUntil.Value - DateTime.UtcNow).Days) days
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fa-solid fa-tags"></i>
                    <h3>No Discounts Created</h3>
                    <p>Create your first discount code to start offering promotions to customers.</p>
                    <a href="@Url.Action("CreateDiscount")" class="btn-primary">Create Discount</a>
                </div>
            }
        </div>
    </div>
</div>

<style>
.discount-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
}

.discount-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.25rem;
    transition: .3s;
    position: relative;
}

.discount-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,.08);
    transform: translateY(-2px);
}

.discount-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: .75rem;
}

.discount-name {
    font-size: .95rem;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.3;
}

.discount-code {
    display: flex;
    align-items: center;
    gap: .5rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: .5rem .75rem;
    margin-bottom: .75rem;
    font-family: 'Courier New', monospace;
}

.code-text {
    font-size: .85rem;
    font-weight: 600;
    color: #6366f1;
    flex: 1;
}

.btn-copy {
    background: none;
    border: none;
    color: #64748b;
    cursor: pointer;
    padding: .25rem;
    border-radius: 4px;
    transition: .2s;
}

.btn-copy:hover {
    background: #e2e8f0;
    color: #1e293b;
}

.discount-desc {
    font-size: .8rem;
    color: #64748b;
    margin-bottom: .75rem;
    line-height: 1.4;
}

.discount-details {
    margin-bottom: 1rem;
}

.detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: .3rem 0;
    border-bottom: 1px solid #f1f5f9;
    font-size: .8rem;
}

.detail-row:last-child {
    border-bottom: none;
}

.detail-label {
    color: #64748b;
    font-weight: 500;
}

.detail-value {
    color: #1e293b;
    font-weight: 600;
}

.discount-actions {
    display: flex;
    gap: .4rem;
    align-items: center;
}

.expiry-warning {
    position: absolute;
    top: -8px;
    right: 1rem;
    background: #fff7ed;
    color: #ea580c;
    font-size: .7rem;
    font-weight: 600;
    padding: .25rem .5rem;
    border-radius: 4px;
    border: 1px solid #fed7aa;
    display: flex;
    align-items: center;
    gap: .25rem;
}

.status-expired {
    background: #f1f5f9;
    color: #64748b;
}
</style>

<script>
function filterDiscounts(status) {
    const cards = document.querySelectorAll('.discount-card');
    cards.forEach(card => {
        if (!status || card.dataset.status === status.toLowerCase()) {
            card.style.display = 'block';
        } else {
            card.style.display = 'none';
        }
    });
}

function searchDiscounts(query) {
    const cards = document.querySelectorAll('.discount-card');
    const searchTerm = query.toLowerCase();
    
    cards.forEach(card => {
        const code = card.dataset.code;
        const name = card.querySelector('.discount-name').textContent.toLowerCase();
        
        if (code.includes(searchTerm) || name.includes(searchTerm)) {
            card.style.display = 'block';
        } else {
            card.style.display = 'none';
        }
    });
}

function copyCode(code) {
    navigator.clipboard.writeText(code).then(() => {
        // Show temporary success message
        const toast = document.createElement('div');
        toast.className = 'alert-toast success';
        toast.innerHTML = '<i class="fa-solid fa-check"></i> Code copied to clipboard!';
        document.body.appendChild(toast);
        
        setTimeout(() => {
            document.body.removeChild(toast);
        }, 3000);
    });
}

function viewUsageDetails(discountId) {
    // This would typically open a modal or navigate to a detailed usage page
    alert('Usage details for discount ID: ' + discountId + '\n\nThis would show detailed usage statistics, customer usage history, and revenue impact.');
}
</script>

@functions {
    string GetStatusClass(string status)
    {
        return status.ToLower() switch
        {
            "active" => "status-active",
            "inactive" => "status-closed",
            "expired" => "status-expired",
            _ => "status-draft"
        };
    }

    string GetApplicableToText(string applicableTo)
    {
        return applicableTo switch
        {
            "AllPlans" => "All Plans",
            "SpecificPlans" => "Selected Plans",
            "NewCustomers" => "New Customers Only",
            _ => "All Plans"
        };
    }
}