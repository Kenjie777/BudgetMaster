@model BudgetMasterFinal.Models.BillingDiscount
@{
    ViewData["Title"] = "Edit Discount";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <h1>Edit Discount</h1>
    <p>Modify discount code details and settings</p>
</div>

<div class="content-wrapper">
    <div class="card">
        <div class="card-header">
            <h3>Discount Details</h3>
            <a href="@Url.Action("Discounts")" class="btn btn-secondary">Back to Discounts</a>
        </div>
        <div class="card-body">
            <form asp-action="EditDiscount" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label asp-for="Code">Discount Code</label>
                        <input asp-for="Code" class="form-control" required />
                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-6">
                        <label asp-for="Name">Display Name</label>
                        <input asp-for="Name" class="form-control" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Description">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-row">
                    <div class="form-group col-md-4">
                        <label asp-for="DiscountType">Discount Type</label>
                        <select asp-for="DiscountType" class="form-control" id="discountType" required>
                            <option value="Percentage">Percentage</option>
                            <option value="FixedAmount">Fixed Amount</option>
                        </select>
                        <span asp-validation-for="DiscountType" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-4">
                        <label asp-for="DiscountValue">Discount Value</label>
                        <div class="input-group">
                            <input asp-for="DiscountValue" class="form-control" type="number" step="0.01" min="0" required />
                            <div class="input-group-append">
                                <span class="input-group-text" id="discountUnit">@(Model.DiscountType == "Percentage" ? "%" : "₱")</span>
                            </div>
                        </div>
                        <span asp-validation-for="DiscountValue" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-4">
                        <label asp-for="Status">Status</label>
                        <select asp-for="Status" class="form-control">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label asp-for="ValidFrom">Valid From (Optional)</label>
                        <input asp-for="ValidFrom" class="form-control" type="datetime-local" />
                        <span asp-validation-for="ValidFrom" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-6">
                        <label asp-for="ValidUntil">Valid Until (Optional)</label>
                        <input asp-for="ValidUntil" class="form-control" type="datetime-local" />
                        <span asp-validation-for="ValidUntil" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label asp-for="MaxUsageCount">Maximum Usage Count (Optional)</label>
                        <input asp-for="MaxUsageCount" class="form-control" type="number" min="1" />
                        <span asp-validation-for="MaxUsageCount" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-6">
                        <label asp-for="MaxUsagePerTenant">Max Usage Per Tenant (Optional)</label>
                        <input asp-for="MaxUsagePerTenant" class="form-control" type="number" min="1" />
                        <span asp-validation-for="MaxUsagePerTenant" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label asp-for="MinimumOrderAmount">Minimum Order Amount (₱)</label>
                        <input asp-for="MinimumOrderAmount" class="form-control" type="number" step="0.01" min="0" />
                        <span asp-validation-for="MinimumOrderAmount" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-6">
                        <label asp-for="ApplicableTo">Applicable To</label>
                        <select asp-for="ApplicableTo" class="form-control" id="applicableTo">
                            <option value="AllPlans">All Plans</option>
                            <option value="SpecificPlans">Specific Plans</option>
                        </select>
                    </div>
                </div>

                <div class="form-group" id="planSelection" style="display: @(Model.ApplicableTo == "SpecificPlans" ? "block" : "none");">
                    <label>Select Applicable Plans</label>
                    <div class="checkbox-list">
                        @{
                            var selectedPlanIds = new List<int>();
                            if (!string.IsNullOrEmpty(Model.ApplicablePlanIds))
                            {
                                try
                                {
                                    selectedPlanIds = System.Text.Json.JsonSerializer.Deserialize<List<int>>(Model.ApplicablePlanIds);
                                }
                                catch { }
                            }
                        }
                        @foreach (var plan in ViewBag.Plans as List<BudgetMasterFinal.Models.SubscriptionPlan>)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="selectedPlanIds" value="@plan.Id" id="plan_@plan.Id" 
                                       @(selectedPlanIds.Contains(plan.Id) ? "checked" : "") />
                                <label class="form-check-label" for="plan_@plan.Id">
                                    @plan.Name - ₱@plan.MonthlyPrice.ToString("N0")/month
                                </label>
                            </div>
                        }
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Update Discount</button>
                    <a href="@Url.Action("Discounts")" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3>Usage Statistics</h3>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <div class="stat-item">
                        <label>Current Usage</label>
                        <value>@Model.CurrentUsageCount</value>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-item">
                        <label>Max Usage</label>
                        <value>@(Model.MaxUsageCount?.ToString() ?? "Unlimited")</value>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-item">
                        <label>Remaining</label>
                        <value>@(Model.MaxUsageCount.HasValue ? (Model.MaxUsageCount.Value - Model.CurrentUsageCount).ToString() : "Unlimited")</value>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('discountType').addEventListener('change', function() {
            const unit = document.getElementById('discountUnit');
            if (this.value === 'Percentage') {
                unit.textContent = '%';
            } else if (this.value === 'FixedAmount') {
                unit.textContent = '₱';
            }
        });

        document.getElementById('applicableTo').addEventListener('change', function() {
            const planSelection = document.getElementById('planSelection');
            if (this.value === 'SpecificPlans') {
                planSelection.style.display = 'block';
            } else {
                planSelection.style.display = 'none';
            }
        });
    </script>
}

<style>
.checkbox-list {
    max-height: 200px;
    overflow-y: auto;
    border: 1px solid #e5e7eb;
    border-radius: 4px;
    padding: 1rem;
}

.checkbox-list .form-check {
    margin-bottom: 0.5rem;
}

.stat-item {
    text-align: center;
    padding: 1rem;
    background: #f8f9fa;
    border-radius: 8px;
}

.stat-item label {
    display: block;
    font-weight: 600;
    color: #6b7280;
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
}

.stat-item value {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: #1f2937;
}
</style>