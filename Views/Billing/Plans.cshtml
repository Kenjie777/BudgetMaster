@model IEnumerable<BudgetMasterFinal.Models.SubscriptionPlan>
@{
    ViewData["Title"] = "Subscription Plans";
    ViewData["PageTitle"] = "Subscription Plans";
    Layout = "_DashboardLayout";
}

<div class="dash-container">
    <div class="kpi-grid">
        <div class="kpi-card blue">
            <div class="kpi-icon"><i class="fa-solid fa-layer-group"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">Total Plans</div>
                <div class="kpi-value">@Model.Count()</div>
                <div class="kpi-sub">Available plans</div>
            </div>
        </div>
        <div class="kpi-card green">
            <div class="kpi-icon"><i class="fa-solid fa-check-circle"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">Active Plans</div>
                <div class="kpi-value">@Model.Count(p => p.Status == "Active")</div>
                <div class="kpi-sub">Currently available</div>
            </div>
        </div>
        <div class="kpi-card orange">
            <div class="kpi-icon"><i class="fa-solid fa-dollar-sign"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">Price Range</div>
                <div class="kpi-value">₱@(Model.Any() ? Model.Min(p => p.MonthlyPrice).ToString("N0") : "0") - ₱@(Model.Any() ? Model.Max(p => p.MonthlyPrice).ToString("N0") : "0")</div>
                <div class="kpi-sub">Monthly pricing</div>
            </div>
        </div>
        <div class="kpi-card purple">
            <div class="kpi-icon"><i class="fa-solid fa-users"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">Total Subscriptions</div>
                <div class="kpi-value">@Model.Sum(p => p.Subscriptions?.Count ?? 0)</div>
                <div class="kpi-sub">Across all plans</div>
            </div>
        </div>
    </div>

    <div class="dash-card">
        <div class="card-header">
            <div class="card-title"><i class="fa-solid fa-layer-group"></i> Subscription Plans</div>
            <a href="@Url.Action("CreatePlan")" class="btn-primary">
                <i class="fa-solid fa-plus"></i> Create New Plan
            </a>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="plans-grid">
                    @foreach (var plan in Model.OrderBy(p => p.SortOrder))
                    {
                        <div class="plan-card @(plan.Status == "Active" ? "active" : "inactive")">
                            <div class="plan-header">
                                <div class="plan-title">
                                    <h3>@plan.Name</h3>
                                    <span class="status-badge @(plan.Status == "Active" ? "status-active" : "status-closed")">
                                        @plan.Status
                                    </span>
                                </div>
                                <div class="plan-pricing">
                                    <div class="price-monthly">
                                        <span class="currency">₱</span>
                                        <span class="amount">@plan.MonthlyPrice.ToString("N0")</span>
                                        <span class="period">/month</span>
                                    </div>
                                    <div class="price-yearly">
                                        ₱@plan.YearlyPrice.ToString("N0")/year
                                        @if (plan.YearlyPrice < plan.MonthlyPrice * 12)
                                        {
                                            <span class="savings">Save @(((plan.MonthlyPrice * 12 - plan.YearlyPrice) / (plan.MonthlyPrice * 12) * 100).ToString("F0"))%</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="plan-description">
                                @plan.Description
                            </div>

                            <div class="plan-limits">
                                <div class="limit-item">
                                    <i class="fa-solid fa-users"></i>
                                    <span>@(plan.MaxUsers == -1 ? "Unlimited" : plan.MaxUsers.ToString()) Users</span>
                                </div>
                                <div class="limit-item">
                                    <i class="fa-solid fa-sitemap"></i>
                                    <span>@(plan.MaxDepartments == -1 ? "Unlimited" : plan.MaxDepartments.ToString()) Departments</span>
                                </div>
                            </div>

                            <div class="plan-features">
                                <h4>Features Included</h4>
                                <div class="features-list">
                                    @if (plan.IncludesForecasting)
                                    {
                                        <div class="feature-item">
                                            <i class="fa-solid fa-chart-line"></i>
                                            <span>Financial Forecasting</span>
                                        </div>
                                    }
                                    @if (plan.IncludesScenarioPlanning)
                                    {
                                        <div class="feature-item">
                                            <i class="fa-solid fa-diagram-project"></i>
                                            <span>Scenario Planning</span>
                                        </div>
                                    }
                                    @if (plan.IncludesAdvancedReports)
                                    {
                                        <div class="feature-item">
                                            <i class="fa-solid fa-chart-bar"></i>
                                            <span>Advanced Reports</span>
                                        </div>
                                    }
                                    @if (plan.IncludesApiAccess)
                                    {
                                        <div class="feature-item">
                                            <i class="fa-solid fa-code"></i>
                                            <span>API Access</span>
                                        </div>
                                    }
                                    @if (plan.IncludesCustomBranding)
                                    {
                                        <div class="feature-item">
                                            <i class="fa-solid fa-palette"></i>
                                            <span>Custom Branding</span>
                                        </div>
                                    }
                                    @if (plan.IncludesPrioritySupport)
                                    {
                                        <div class="feature-item">
                                            <i class="fa-solid fa-headset"></i>
                                            <span>Priority Support</span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="plan-stats">
                                <div class="stat-item">
                                    <span class="stat-label">Active Subscriptions</span>
                                    <span class="stat-value">@(plan.Subscriptions?.Count(s => s.Status == "Active") ?? 0)</span>
                                </div>
                            </div>

                            <div class="plan-actions">
                                <a href="@Url.Action("EditPlan", new { id = plan.Id })" class="btn-secondary">
                                    <i class="fa-solid fa-edit"></i> Edit Plan
                                </a>
                                @if (plan.Status == "Active")
                                {
                                    <a href="@Url.Action("DeactivatePlan", new { id = plan.Id })" 
                                       class="btn-secondary"
                                       onclick="return confirm('Are you sure you want to deactivate this plan?')">
                                        <i class="fa-solid fa-pause"></i> Deactivate
                                    </a>
                                }
                                else
                                {
                                    <a href="@Url.Action("ActivatePlan", new { id = plan.Id })" 
                                       class="btn-secondary">
                                        <i class="fa-solid fa-play"></i> Activate
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fa-solid fa-layer-group"></i>
                    <h3>No Subscription Plans</h3>
                    <p>Create your first subscription plan to start managing pricing tiers.</p>
                    <a href="@Url.Action("CreatePlan")" class="btn-primary">
                        <i class="fa-solid fa-plus"></i> Create First Plan
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
.feature-list {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
}

.feature-badge {
    background-color: #e3f2fd;
    color: #1976d2;
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 11px;
    font-weight: 500;
}

.status-badge {
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: bold;
    text-transform: uppercase;
}

.status-active {
    background-color: #d4edda;
    color: #155724;
}

.status-inactive {
    background-color: #f8d7da;
    color: #721c24;
}

.action-buttons {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
}

.btn-sm {
    padding: 4px 8px;
    font-size: 12px;
}
</style>

<style>
.page-header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
}

.page-header h1 {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0;
    color: #1f2937;
}

.page-header-actions {
    display: flex;
    gap: 1rem;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.stat-card {
    background: white;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    gap: 1rem;
    border: 1px solid #e5e7eb;
    transition: all 0.3s ease;
}

.stat-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px -5px rgba(0, 0, 0, 0.1);
}

.stat-icon {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: white;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.stat-icon.active {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.stat-icon.price {
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
}

.stat-icon.users {
    background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
}

.stat-content h3 {
    margin: 0 0 0.5rem 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.stat-value {
    font-size: 2rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0;
}

.plans-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 2rem;
}

.plan-card {
    background: white;
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    border: 2px solid #e5e7eb;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.plan-card.active {
    border-color: #10b981;
    box-shadow: 0 8px 25px -5px rgba(16, 185, 129, 0.2);
}

.plan-card.active::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #10b981, #059669);
}

.plan-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px -10px rgba(0, 0, 0, 0.15);
}

.plan-header {
    margin-bottom: 1.5rem;
}

.plan-title {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
}

.plan-title h3 {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 700;
    color: #1f2937;
}

.plan-pricing {
    text-align: left;
}

.price-monthly {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
}

.currency {
    font-size: 1.25rem;
    font-weight: 600;
    color: #6b7280;
}

.amount {
    font-size: 2.5rem;
    font-weight: 800;
    color: #1f2937;
}

.period {
    font-size: 1rem;
    color: #6b7280;
}

.price-yearly {
    font-size: 0.875rem;
    color: #6b7280;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.savings {
    background: #dcfce7;
    color: #166534;
    padding: 0.125rem 0.5rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
}

.plan-description {
    color: #6b7280;
    margin-bottom: 1.5rem;
    line-height: 1.6;
}

.plan-limits {
    margin-bottom: 1.5rem;
}

.limit-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    color: #374151;
}

.limit-item i {
    width: 16px;
    color: #6b7280;
}

.plan-features h4 {
    margin: 0 0 1rem 0;
    font-size: 1rem;
    font-weight: 600;
    color: #1f2937;
}

.features-list {
    margin-bottom: 1.5rem;
}

.feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    color: #374151;
}

.feature-item i {
    width: 16px;
    color: #10b981;
}

.plan-stats {
    background: #f9fafb;
    border-radius: 12px;
    padding: 1rem;
    margin-bottom: 1.5rem;
}

.stat-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.stat-label {
    color: #6b7280;
    font-size: 0.875rem;
}

.stat-value {
    font-weight: 600;
    color: #1f2937;
}

.plan-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
}

.btn {
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.2s ease;
    border: 2px solid transparent;
    cursor: pointer;
}

.btn-primary {
    background: #4f46e5;
    color: white;
}

.btn-primary:hover {
    background: #4338ca;
    transform: translateY(-1px);
}

.btn-outline-primary {
    background: transparent;
    color: #4f46e5;
    border-color: #4f46e5;
}

.btn-outline-primary:hover {
    background: #4f46e5;
    color: white;
}

.btn-outline-warning {
    background: transparent;
    color: #f59e0b;
    border-color: #f59e0b;
}

.btn-outline-warning:hover {
    background: #f59e0b;
    color: white;
}

.btn-outline-success {
    background: transparent;
    color: #10b981;
    border-color: #10b981;
}

.btn-outline-success:hover {
    background: #10b981;
    color: white;
}

.status-badge {
    padding: 0.375rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.status-active {
    background: #dcfce7;
    color: #166534;
}

.status-inactive {
    background: #fef3c7;
    color: #92400e;
}

.empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: white;
    border-radius: 20px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
}

.empty-icon {
    font-size: 4rem;
    color: #d1d5db;
    margin-bottom: 1.5rem;
}

.empty-state h3 {
    margin: 0 0 0.5rem 0;
    color: #1f2937;
    font-size: 1.5rem;
}

.empty-state p {
    color: #6b7280;
    margin-bottom: 2rem;
}

@@media (max-width: 768px) {
    .page-header-content {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
    }
    
    .plans-grid {
        grid-template-columns: 1fr;
    }
    
    .plan-actions {
        flex-direction: column;
    }
    
    .btn {
        justify-content: center;
    }
}
</style>

