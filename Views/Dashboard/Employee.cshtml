@model BudgetMasterFinal.Models.ViewModels.EmployeeDashboardViewModel
@{
    ViewData["Title"] = "Employee Dashboard";
    ViewData["PageTitle"] = "My Workspace";
    Layout = "_DashboardLayout";
}
<div class="dash-container">
    <div class="dash-card" style="margin-bottom:1.5rem;background:linear-gradient(135deg,#0ea5e9,#6366f1);color:#fff;border:none;">
        <div class="card-body" style="display:flex;align-items:center;gap:1.5rem;padding:1.5rem;">
            <div style="font-size:3rem;opacity:0.8;"><i class="fa-solid fa-user-circle"></i></div>
            <div>
                <div style="font-size:0.8rem;opacity:0.8;text-transform:uppercase;letter-spacing:.05em;">@(Model.Department?.Name ?? "General")</div>
                <div style="font-size:1.4rem;font-weight:700;">@Model.WelcomeMessage</div>
                <div style="opacity:0.8;font-size:0.9rem;">Employee Portal</div>
            </div>
            <div style="margin-left:auto;">
                <a href="/Budget/CreateRequest" class="btn-primary" style="background:rgba(255,255,255,0.2);border:1px solid rgba(255,255,255,0.4);">
                    <i class="fa-solid fa-plus"></i> New Request
                </a>
            </div>
        </div>
    </div>

    <div class="kpi-grid" style="grid-template-columns:repeat(auto-fit,minmax(180px,1fr));">
        <div class="kpi-card blue">
            <div class="kpi-icon"><i class="fa-solid fa-file-invoice-dollar"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">Total Requests</div>
                <div class="kpi-value">@Model.TotalRequests</div>
                <div class="kpi-sub">All-time</div>
            </div>
        </div>
        <div class="kpi-card orange">
            <div class="kpi-icon"><i class="fa-solid fa-hourglass-half"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">Pending</div>
                <div class="kpi-value">@Model.PendingRequests</div>
                <div class="kpi-sub">Awaiting review</div>
            </div>
        </div>
        <div class="kpi-card green">
            <div class="kpi-icon"><i class="fa-solid fa-circle-check"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">Approved</div>
                <div class="kpi-value">@Model.ApprovedRequests</div>
                <div class="kpi-sub">â‚±@Model.TotalApprovedAmount.ToString("N0") total</div>
            </div>
        </div>
        <div class="kpi-card red">
            <div class="kpi-icon"><i class="fa-solid fa-circle-xmark"></i></div>
            <div class="kpi-info">
                <div class="kpi-label">Rejected</div>
                <div class="kpi-value">@Model.RejectedRequests</div>
                <div class="kpi-sub">Declined requests</div>
            </div>
        </div>
    </div>

    <div class="dash-card">
        <div class="card-header">
            <div class="card-title"><i class="fa-solid fa-list-check"></i> My Requests</div>
            <a href="/Budget/CreateRequest" class="btn-primary" style="font-size:0.8rem;padding:0.4rem 1rem;">
                <i class="fa-solid fa-plus"></i> New
            </a>
        </div>
        <div class="card-body">
            @if (Model.MyRequests.Any())
            {
                <table class="dash-table">
                    <thead>
                        <tr><th>Title</th><th>Department</th><th>Amount</th><th>Date</th><th>Status</th><th>Notes</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.MyRequests)
                        {
                            <tr>
                                <td><strong>@r.Title</strong></td>
                                <td>@(r.Department?.Name ?? "â€”")</td>
                                <td>â‚±@r.RequestedAmount.ToString("N0")</td>
                                <td>@r.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td><span class="status-badge status-@r.Status.ToLower()">@r.Status</span></td>
                                <td style="color:var(--muted);font-size:0.85rem;">@(r.ReviewerNotes?.Length > 40 ? r.ReviewerNotes.Substring(0, 40) + "â€¦" : r.ReviewerNotes ?? "â€”")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <i class="fa-solid fa-file-invoice-dollar"></i>
                    <p>You haven't submitted any requests yet.</p>
                    <a href="/Budget/CreateRequest" class="btn-primary" style="margin-top:1rem;display:inline-flex;">Submit Your First Request</a>
                </div>
            }
        </div>
    </div>
</div>

